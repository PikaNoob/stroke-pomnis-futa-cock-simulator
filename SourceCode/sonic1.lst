0000D212 08A9 0005 0022             		bclr	#5,$22(a1)
0000D218 7207                       		moveq	#7,d1		; load 8 fragments
0000D21A 343C 0070                  		move.w	#$70,d2
0000D21E 6100                       		bsr.s	SmashObject
