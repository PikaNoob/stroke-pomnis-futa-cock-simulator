0000D50E                            
0000D50E                            ObjectFall:
0000D50E 3028 0010                  		move.w	$10(a0),d0
0000D512 48C0                       		ext.l	d0
0000D514 E188                       		lsl.l	#8,d0
0000D516 D1A8 0008                  		add.l	d0,8(a0)
0000D51A 3028 0012                  		move.w	$12(a0),d0
0000D51E 0668 0038 0012             		addi.w	#$38,$12(a0)	; increase vertical speed
0000D524 48C0                       		ext.l	d0
0000D526 E188                       		lsl.l	#8,d0
0000D528 D1A8 000C                  		add.l	d0,$C(a0)
0000D52C 4E75                       		rts	
