00001CE0 51C8 FFFC                  		dbf	d0,loc_1DFA
00001CE4 0C38 0001 FE10             		cmpi.b	#1,($FFFFFE10).w
00001CEA 6600                       		bne.s	locret_1E24
00001CEC 7000                       		moveq	#0,d0
00001CEE 41F8 FA80                  		lea	($FFFFFA80).w,a0
00001CF2 43F8 FA00                  		lea	($FFFFFA00).w,a1
00001CF6 1038 F626                  		move.b	($FFFFF626).w,d0
00001CFA D0C0                       		adda.w	d0,a0
00001CFC D2C0                       		adda.w	d0,a1
00001CFE 1038 F627                  		move.b	($FFFFF627).w,d0
