00001E0C 1038 F626                          move.b ($FFFFF626).w,d0
00001E10 D0C0                               adda.w d0,a0
00001E12 D2C0                               adda.w d0,a1
00001E14 1038 F627                          move.b ($FFFFF627).w,d0
00001E18                            
00001E18                            loc_1F20:
00001E18 6100                               bsr.s Pal_DecColor2
00001E1A 51C8 FFFC                          dbf d0,loc_1F20
00001E1E 0C38 0001 FE10                     cmpi.b #1,($FFFFFE10).w
00001E24 6600                               bne.s locret_1F4A
00001E26 7000                               moveq #0,d0
00001E28 41F8 FA80                          lea ($FFFFFA80).w,a0
00001E2C 43F8 FA00                          lea ($FFFFFA00).w,a1
00001E30 1038 F626                          move.b ($FFFFF626).w,d0
00001E34 D0C0                               adda.w d0,a0
00001E36 D2C0                               adda.w d0,a1
00001E38 1038 F627                          move.b ($FFFFF627).w,d0
