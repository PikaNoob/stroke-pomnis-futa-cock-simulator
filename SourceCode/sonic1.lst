0000144C                            ; ===========================================================================
0000144C                            ; Subroutines to put PLC block into the queue
0000144C                            ; ===========================================================================
0000144C                            ; Note:		Queue can hold no more than 21 items
0000144C                            ; Input:	d0 - PLC block index
0000144C                            ; ---------------------------------------------------------------------------
0000144C                            
0000144C                            LoadPLC:
0000144C 48E7 0060                  		movem.l	a1-a2,-(sp)	; move registers to the stack
00001450 43F9 0000 0000             		lea	(ArtLoadCues).l,a1
00001456 D040                       		add.w	d0,d0		; double block index
00001458 3031 0000                  		move.w	(a1,d0.w),d0
0000145C 43F1 0000                  		lea	(a1,d0.w),a1	 ; load PLC block to a1
00001460 45F8 F680                  		lea	($FFFFF680).w,a2 ; load PLC queue to a2
00001464                            
00001464                            @FindSlot:
00001464 4A92                       		tst.l	(a2)		; is the slot in queue empty?
00001466 6700                       		beq.s	@AddToQueue	; if yes, branch
00001468 5C4A                       		addq.w	#6,a2		; next slot
0000146A 60F8                       		bra.s	@FindSlot
0000146C                            ; ===========================================================================
0000146C                            
0000146C                            @AddToQueue:
0000146C 3019                       		move.w	(a1)+,d0	; move number of items in block to d0
0000146E 6B00                       		bmi.s	LoadPLC_Rts	; if it's negative (>=$80), then something is wrong, exit
00001470                            
00001470                            @WriteCues:
00001470 24D9                       		move.l	(a1)+,(a2)+
00001472 34D9                       		move.w	(a1)+,(a2)+
00001474 51C8 FFFA                  		dbf	d0,@WriteCues	; repeat for the number of items
00001478                            
00001478                            LoadPLC_Rts:
00001478 4CDF 0600                  		movem.l	(sp)+,a1-a2	; load saved registers from the stack
0000147C 4E75                       		rts	
0000147E                            ; End of function LoadPLC
