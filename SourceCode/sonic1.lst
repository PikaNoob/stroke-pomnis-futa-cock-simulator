0000A76E                            ; ---------------------------------------------------------------------------
0000A76E                            ; Subroutine to	animate	a sprite using an animation script
0000A76E                            ; ---------------------------------------------------------------------------
0000A76E                            
0000A76E                            ; ||||||||||||||| S U B	R O U T	I N E |||||||||||||||||||||||||||||||||||||||
0000A76E                            
0000A76E                            
0000A76E                            AnimateSprite:
0000A76E 7000                       		moveq	#0,d0
0000A770 1028 001C                  		move.b	$1C(a0),d0	; move animation number	to d0
0000A774 B028 001D                  		cmp.b	$1D(a0),d0	; is animation set to restart?
0000A778 6700                       		beq.s	Anim_Run	; if not, branch
0000A77A 1140 001D                  		move.b	d0,$1D(a0)	; set to "no restart"
0000A77E 117C 0000 001B             		move.b	#0,$1B(a0)	; reset	animation
0000A784 117C 0000 001E             		move.b	#0,$1E(a0)	; reset	frame duration
0000A78A                            
0000A78A                            Anim_Run:
0000A78A 5328 001E                  		subq.b	#1,$1E(a0)	; subtract 1 from frame	duration
0000A78E 6A00                       		bpl.s	Anim_Wait	; if time remains, branch
0000A790 D040                       		add.w	d0,d0
0000A792 D2F1 0000                  		adda.w	(a1,d0.w),a1	; jump to appropriate animation	script
0000A796 1151 001E                  		move.b	(a1),$1E(a0)	; load frame duration
0000A79A 7200                       		moveq	#0,d1
0000A79C 1228 001B                  		move.b	$1B(a0),d1	; load current frame number
0000A7A0 1031 1001                  		move.b	1(a1,d1.w),d0	; read sprite number from script
0000A7A4 6B00                       		bmi.s	Anim_End_FF	; if animation is complete, branch
0000A7A6                            
0000A7A6                            Anim_Next:
0000A7A6 1200                       		move.b	d0,d1
0000A7A8 0200 001F                  		andi.b	#$1F,d0
0000A7AC 1140 001A                  		move.b	d0,$1A(a0)	; load sprite number
0000A7B0 1028 0022                  		move.b	$22(a0),d0
0000A7B4 E719                       		rol.b	#3,d1
0000A7B6 B101                       		eor.b	d0,d1
0000A7B8 0201 0003                  		andi.b	#3,d1
0000A7BC 0228 00FC 0001             		andi.b	#$FC,1(a0)
0000A7C2 8328 0001                  		or.b	d1,1(a0)
0000A7C6 5228 001B                  		addq.b	#1,$1B(a0)	; next frame number
0000A7CA                            
0000A7CA                            Anim_Wait:
0000A7CA 4E75                       		rts	
0000A7CC                            ; ===========================================================================
0000A7CC                            
0000A7CC                            Anim_End_FF:
0000A7CC 5200                       		addq.b	#1,d0		; is the end flag = $FF	?
0000A7CE 6600                       		bne.s	Anim_End_FE	; if not, branch
0000A7D0 117C 0000 001B             		move.b	#0,$1B(a0)	; restart the animation
0000A7D6 1029 0001                  		move.b	1(a1),d0	; read sprite number
0000A7DA 60CA                       		bra.s	Anim_Next
0000A7DC                            ; ===========================================================================
0000A7DC                            
0000A7DC                            Anim_End_FE:
0000A7DC 5200                       		addq.b	#1,d0		; is the end flag = $FE	?
0000A7DE 6600                       		bne.s	Anim_End_FD	; if not, branch
0000A7E0 1031 1002                  		move.b	2(a1,d1.w),d0	; read the next	byte in	the script
0000A7E4 9128 001B                  		sub.b	d0,$1B(a0)	; jump back d0 bytes in	the script
0000A7E8 9200                       		sub.b	d0,d1
0000A7EA 1031 1001                  		move.b	1(a1,d1.w),d0	; read sprite number
0000A7EE 60B6                       		bra.s	Anim_Next
0000A7F0                            ; ===========================================================================
0000A7F0                            
0000A7F0                            Anim_End_FD:
0000A7F0 5200                       		addq.b	#1,d0		; is the end flag = $FD	?
0000A7F2 6600                       		bne.s	Anim_End_FC	; if not, branch
0000A7F4 1171 1002 001C             		move.b	2(a1,d1.w),$1C(a0) ; read next byte, run that animation
0000A7FA                            
0000A7FA                            Anim_End_FC:
0000A7FA 5200                       		addq.b	#1,d0		; is the end flag = $FC	?
0000A7FC 6600                       		bne.s	Anim_End_FB	; if not, branch
0000A7FE 5428 0024                  		addq.b	#2,$24(a0)	; jump to next routine
0000A802                            
0000A802                            Anim_End_FB:
0000A802 5200                       		addq.b	#1,d0		; is the end flag = $FB	?
0000A804 6600                       		bne.s	Anim_End_FA	; if not, branch
0000A806 117C 0000 001B             		move.b	#0,$1B(a0)	; reset	animation
0000A80C 4228 0025                  		clr.b	$25(a0)		; reset	2nd routine counter
0000A810                            
0000A810                            Anim_End_FA:
0000A810 5200                       		addq.b	#1,d0		; is the end flag = $FA	?
0000A812 6600                       		bne.s	Anim_End	; if not, branch
0000A814 5428 0025                  		addq.b	#2,$25(a0)	; jump to next routine
0000A818                            
0000A818                            Anim_End:
0000A818 4E75                       		rts	
0000A81A                            ; End of function AnimateSprite
