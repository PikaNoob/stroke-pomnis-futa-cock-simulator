0001402E 6700                       		beq.s	SAnim_Do	; if not, branch
00014030 1140 001D                  		move.b	d0,$1D(a0)	; set to "no restart"
00014034 117C 0000 001B             		move.b	#0,$1B(a0)	; reset	animation
0001403A 117C 0000 001E             		move.b	#0,$1E(a0)	; reset	frame duration
00014040                            
00014040                            SAnim_Do:
00014040 D040                       		add.w	d0,d0
00014042 D2F1 0000                  		adda.w	(a1,d0.w),a1	; jump to appropriate animation	script
00014046 1011                       		move.b	(a1),d0
00014048 6B00                       		bmi.s	SAnim_WalkRun	; if animation is walk/run/roll/jump, branch
0001404A 1228 0022                  		move.b	$22(a0),d1
