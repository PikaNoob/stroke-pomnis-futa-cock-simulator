0001CD32 6700                       		beq.s	Hud_End		; if not, branch
0001CD34 4238 F7D6                  		clr.b	($FFFFF7D6).w
0001CD42 7200                       		moveq	#0,d1
0001CD44 3238 F7D2                  		move.w	($FFFFF7D2).w,d1 ; load	time bonus
0001CD48 6100 0000                  		bsr.w	Hud_TimeRingBonus
0001CD4C 7200                       		moveq	#0,d1
0001CD4E 3238 F7D4                  		move.w	($FFFFF7D4).w,d1 ; load	ring bonus
0001CD52 6100 0000                  		bsr.w	Hud_TimeRingBonus
0001CD56                            
0001CD56                            Hud_End:
0001CD56 4E75                       		rts	
0001CD58                            ; ===========================================================================
0001CD58                            
0001CD58                            TimeOver:				; XREF: Hud_ChkTime
