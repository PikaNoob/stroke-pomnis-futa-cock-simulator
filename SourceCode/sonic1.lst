000029BC                            ; Subroutine to calculate sine and cosine
000029BC                            ; ===========================================================================
000029BC                            ; Input:	d0 - Angle (0-$FF)
000029BC                            ; Output:	d0 - Sine
000029BC                            ;		d1 - Cosine
000029BC                            ; ---------------------------------------------------------------------------
000029BC                            
000029BC                            CalcSine:
000029BC 0240 00FF                  		andi.w	#$FF,d0
000029C0 D040                       		add.w	d0,d0
000029C2 0640 0080                  		addi.w	#$80,d0
000029C6 323B 0000                  		move.w	Sine_Data(pc,d0.w),d1	; get cosine
000029CA 0440 0080                  		subi.w	#$80,d0
000029CE 303B 0000                  		move.w	Sine_Data(pc,d0.w),d0	; get sine
000029D2 4E75                       		rts	
000029D4                            
000029D4                            Sine_Data:	incbin	misc\sinewave.bin	; pre-calculated Sine values
00002C54                            
00002C54                            ; End of function CalcSine
