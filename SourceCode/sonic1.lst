00003442                            ; ---------------------------------------------------------------------------
00003442                            ; Subroutine to	change what you're selecting in the level select
00003442                            ; ---------------------------------------------------------------------------
00003442                            
00003442                            ; ||||||||||||||| S U B	R O U T	I N E |||||||||||||||||||||||||||||||||||||||
00003442                            
00003442                            
00003442                            LevSelControls:				; XREF: LevelSelect
00003442 1238 F605                  		move.b	(Joypad|Press),d1
00003446 0201 0003                  		andi.b	#Up+Down,d1	; is up/down held?
0000344A 6600                       		bne.s	LevSel_UpDown	; if yes, branch
0000344C 5378 FF80                  		subq.w	#1,($FFFFFF80).w ; subtract 1 from time	until next move
00003450 6A00                       		bpl.s	LevSel_SndTest	; if time remains, branch
00003452                            
00003452                            LevSel_UpDown:
00003452 31FC 000B FF80             		move.w	#$B,($FFFFFF80).w ; reset time delay
00003458 1238 F604                  		move.b	(Joypad|Held),d1
0000345C 0201 0003                  		andi.b	#Up+Down,d1	; is up/down held?
00003460 6700                       		beq.s	LevSel_SndTest	; if not, branch
00003462 3038 FF82                  		move.w	($FFFFFF82).w,d0
00003466 0801 0000                  		btst	#iUp,d1		; is up	held?
0000346A 6700                       		beq.s	LevSel_Down	; if not, branch
0000346C 5340                       		subq.w	#1,d0		; move up 1 selection
0000346E 6400                       		bcc.s	LevSel_Down
00003470 7014                       		moveq	#$14,d0		; if selection moves below 0, jump to selection	$14
00003472                            
00003472                            LevSel_Down:
00003472 0801 0001                  		btst	#iDown,d1	; is down held?
00003476 6700                       		beq.s	LevSel_Refresh	; if not, branch
00003478 5240                       		addq.w	#1,d0		; move down 1 selection
0000347A 0C40 0015                  		cmpi.w	#$15,d0
0000347E 6500                       		bcs.s	LevSel_Refresh
00003480 7000                       		moveq	#0,d0		; if selection moves above $14,	jump to	selection 0
00003482                            
00003482                            LevSel_Refresh:
00003482 31C0 FF82                  		move.w	d0,($FFFFFF82).w ; set new selection
00003486 6100 0000                  		bsr.w	LevSelTextLoad	; refresh text
0000348A 4E75                       		rts	
0000348C                            ; ===========================================================================
0000348C                            
0000348C                            LevSel_SndTest:				; XREF: LevSelControls
0000348C 0C78 0014 FF82             		cmpi.w	#$14,($FFFFFF82).w ; is	item $14 selected?
00003492 6600                       		bne.s	LevSel_NoMove	; if not, branch
00003494 1238 F605                  		move.b	(Joypad|Press),d1
00003498 0201 000C                  		andi.b	#Left+Right,d1	; is left/right	pressed?
0000349C 6700                       		beq.s	LevSel_NoMove	; if not, branch
0000349E 3038 FF84                  		move.w	($FFFFFF84).w,d0
000034A2 0801 0002                  		btst	#iLeft,d1	; is left pressed?
000034A6 6700                       		beq.s	LevSel_Right	; if not, branch
000034A8 5340                       		subq.w	#1,d0		; subtract 1 from sound	test
000034AA 6400                       		bcc.s	LevSel_Right
000034AC 704F                       		moveq	#$4F,d0		; if sound test	moves below 0, set to $4F
000034AE                            
000034AE                            LevSel_Right:
000034AE 0801 0003                  		btst	#iRight,d1	; is right pressed?
000034B2 6700                       		beq.s	LevSel_Refresh2	; if not, branch
000034B4 5240                       		addq.w	#1,d0		; add 1	to sound test
000034B6 0C40 0050                  		cmpi.w	#$50,d0
000034BA 6500                       		bcs.s	LevSel_Refresh2
000034BC 7000                       		moveq	#0,d0		; if sound test	moves above $4F, set to	0
000034BE                            
000034BE                            LevSel_Refresh2:
000034BE 31C0 FF84                  		move.w	d0,($FFFFFF84).w ; set sound test number
000034C2 6100 0000                  		bsr.w	LevSelTextLoad	; refresh text
000034C6                            
000034C6                            LevSel_NoMove:
000034C6 4E75                       		rts	
000034C8                            ; End of function LevSelControls
