000012D0 6700                       		beq.s	Unpause		; if not, branch
000012D2 4A78 F63A                  		tst.w	($FFFFF63A).w	; is game already paused?
000012D6 6600                       		bne.s	loc_13BE	; if yes, branch
000012D8                            
000012D8 0838 0007 F605             		btst	#iStart,(Joypad|Press)	; is Start button pressed?
000012DE 6700                       		beq.s	Pause_DoNothing		; if not, branch
000012E0                            
000012E0                            loc_13BE:
000012E0 31FC 0001 F63A             		move.w	#1,($FFFFF63A).w ; freeze time
000012E6 11FC 0001 F003             		move.b	#1,($FFFFF003).w ; pause music
000012EC                            
000012EC                            loc_13CA:
