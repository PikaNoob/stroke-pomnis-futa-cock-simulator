00014006                            ; ---------------------------------------------------------------------------
00014006                            ; Subroutine to	animate	Sonic's sprites
00014006                            ; ---------------------------------------------------------------------------
00014006                            
00014006                            ; ||||||||||||||| S U B	R O U T	I N E |||||||||||||||||||||||||||||||||||||||
00014006                            
00014006                            
00014006                            Sonic_Animate:				; XREF: Obj01_Control; et al
00014006 43F9 0000 0000             		lea	(SonicAniData).l,a1
0001400C 7000                       		moveq	#0,d0
0001400E 1028 001C                  		move.b	$1C(a0),d0
00014012 B028 001D                  		cmp.b	$1D(a0),d0	; is animation set to restart?
00014016 6700                       		beq.s	SAnim_Do	; if not, branch
00014018 1140 001D                  		move.b	d0,$1D(a0)	; set to "no restart"
0001401C 117C 0000 001B             		move.b	#0,$1B(a0)	; reset	animation
00014022 117C 0000 001E             		move.b	#0,$1E(a0)	; reset	frame duration
00014028                            
00014028                            SAnim_Do:
00014028 D040                       		add.w	d0,d0
0001402A D2F1 0000                  		adda.w	(a1,d0.w),a1	; jump to appropriate animation	script
0001402E 1011                       		move.b	(a1),d0
00014030 6B00                       		bmi.s	SAnim_WalkRun	; if animation is walk/run/roll/jump, branch
00014032 1228 0022                  		move.b	$22(a0),d1
00014036 0201 0001                  		andi.b	#1,d1
0001403A 0228 00FC 0001             		andi.b	#$FC,1(a0)
00014040 8328 0001                  		or.b	d1,1(a0)
00014044 5328 001E                  		subq.b	#1,$1E(a0)	; subtract 1 from frame	duration
00014048 6A00                       		bpl.s	SAnim_Delay	; if time remains, branch
0001404A 1140 001E                  		move.b	d0,$1E(a0)	; load frame duration
0001404E                            
0001404E                            SAnim_Do2:
0001404E 7200                       		moveq	#0,d1
00014050 1228 001B                  		move.b	$1B(a0),d1	; load current frame number
00014054 1031 1001                  		move.b	1(a1,d1.w),d0	; read sprite number from script
00014058 6B00                       		bmi.s	SAnim_End_FF	; if animation is complete, branch
0001405A                            
0001405A                            SAnim_Next:
0001405A 1140 001A                  		move.b	d0,$1A(a0)	; load sprite number
0001405E 5228 001B                  		addq.b	#1,$1B(a0)	; next frame number
00014062                            
00014062                            SAnim_Delay:
00014062 4E75                       		rts	
00014064                            ; ===========================================================================
00014064                            
00014064                            SAnim_End_FF:
00014064 5200                       		addq.b	#1,d0		; is the end flag = $FF	?
00014066 6600                       		bne.s	SAnim_End_FE	; if not, branch
00014068 117C 0000 001B             		move.b	#0,$1B(a0)	; restart the animation
0001406E 1029 0001                  		move.b	1(a1),d0	; read sprite number
00014072 60E6                       		bra.s	SAnim_Next
00014074                            ; ===========================================================================
00014074                            
00014074                            SAnim_End_FE:
00014074 5200                       		addq.b	#1,d0		; is the end flag = $FE	?
00014076 6600                       		bne.s	SAnim_End_FD	; if not, branch
00014078 1031 1002                  		move.b	2(a1,d1.w),d0	; read the next	byte in	the script
0001407C 9128 001B                  		sub.b	d0,$1B(a0)	; jump back d0 bytes in	the script
00014080 9200                       		sub.b	d0,d1
00014082 1031 1001                  		move.b	1(a1,d1.w),d0	; read sprite number
00014086 60D2                       		bra.s	SAnim_Next
00014088                            ; ===========================================================================
00014088                            
00014088                            SAnim_End_FD:
00014088 5200                       		addq.b	#1,d0		; is the end flag = $FD	?
0001408A 6600                       		bne.s	SAnim_End	; if not, branch
0001408C 1171 1002 001C             		move.b	2(a1,d1.w),$1C(a0) ; read next byte, run that animation
00014092                            
00014092                            SAnim_End:
00014092 4E75                       		rts	
00014094                            ; ===========================================================================
00014094                            
00014094                            SAnim_WalkRun:				; XREF: SAnim_Do
00014094 5328 001E                  		subq.b	#1,$1E(a0)	; subtract 1 from frame	duration
00014098 6AC8                       		bpl.s	SAnim_Delay	; if time remains, branch
0001409A 5200                       		addq.b	#1,d0		; is animation walking/running?
0001409C 6600 0000                  		bne.w	SAnim_RollJump	; if not, branch
000140A0 7200                       		moveq	#0,d1
000140A2 1028 0026                  		move.b	$26(a0),d0	; get Sonic's angle
000140A6 1428 0022                  		move.b	$22(a0),d2
000140AA 0202 0001                  		andi.b	#1,d2		; is Sonic mirrored horizontally?
000140AE 6600                       		bne.s	loc_13A70	; if yes, branch
000140B0 4600                       		not.b	d0		; reverse angle
000140B2                            
000140B2                            loc_13A70:
000140B2 0600 0010                  		addi.b	#$10,d0		; add $10 to angle
000140B6 6A00                       		bpl.s	loc_13A78	; if angle is $0-$7F, branch
000140B8 7203                       		moveq	#3,d1
000140BA                            
000140BA                            loc_13A78:
000140BA 0228 00FC 0001             		andi.b	#$FC,1(a0)
000140C0 B302                       		eor.b	d1,d2
000140C2 8528 0001                  		or.b	d2,1(a0)
000140C6 0828 0005 0022             		btst	#5,$22(a0)
000140CC 6600 0000                  		bne.w	SAnim_Push
000140D0 E808                       		lsr.b	#4,d0		; divide angle by $10
000140D2 0200 0006                  		andi.b	#6,d0		; angle	must be	0, 2, 4	or 6
000140D6 3428 0014                  		move.w	$14(a0),d2	; get Sonic's speed
000140DA 6A00                       		bpl.s	loc_13A9C
000140DC 4442                       		neg.w	d2
000140DE                            
000140DE                            loc_13A9C:
000140DE 43F9 0000 0000             		lea	(SonAni_Run).l,a1 ; use	running	animation
000140E4 0C42 0600                  		cmpi.w	#$600,d2	; is Sonic at running speed?
000140E8 6400                       		bcc.s	loc_13AB4	; if yes, branch
000140EA 43F9 0000 0000             		lea	(SonAni_Walk).l,a1 ; use walking animation
000140F0 1200                       		move.b	d0,d1
000140F2 E209                       		lsr.b	#1,d1
000140F4 D001                       		add.b	d1,d0
000140F6                            
000140F6                            loc_13AB4:
000140F6 D000                       		add.b	d0,d0
000140F8 1600                       		move.b	d0,d3
000140FA 4442                       		neg.w	d2
000140FC 0642 0800                  		addi.w	#$800,d2
00014100 6A00                       		bpl.s	loc_13AC2
00014102 7400                       		moveq	#0,d2
00014104                            
00014104                            loc_13AC2:
00014104 E04A                       		lsr.w	#8,d2
00014106 1142 001E                  		move.b	d2,$1E(a0)	; modify frame duration
0001410A 6100 FF42                  		bsr.w	SAnim_Do2
0001410E D728 001A                  		add.b	d3,$1A(a0)	; modify frame number
00014112 4E75                       		rts	
00014114                            ; ===========================================================================
00014114                            
00014114                            SAnim_RollJump:				; XREF: SAnim_WalkRun
00014114 5200                       		addq.b	#1,d0		; is animation rolling/jumping?
00014116 6600                       		bne.s	SAnim_Push	; if not, branch
00014118 3428 0014                  		move.w	$14(a0),d2	; get Sonic's speed
0001411C 6A00                       		bpl.s	loc_13ADE
0001411E 4442                       		neg.w	d2
00014120                            
00014120                            loc_13ADE:
00014120 43F9 0000 0000             		lea	(SonAni_Roll2).l,a1 ; use fast animation
00014126 0C42 0600                  		cmpi.w	#$600,d2	; is Sonic moving fast?
0001412A 6400                       		bcc.s	loc_13AF0	; if yes, branch
0001412C 43F9 0000 0000             		lea	(SonAni_Roll).l,a1 ; use slower	animation
00014132                            
00014132                            loc_13AF0:
00014132 4442                       		neg.w	d2
00014134 0642 0400                  		addi.w	#$400,d2
00014138 6A00                       		bpl.s	loc_13AFA
0001413A 7400                       		moveq	#0,d2
0001413C                            
0001413C                            loc_13AFA:
0001413C E04A                       		lsr.w	#8,d2
0001413E 1142 001E                  		move.b	d2,$1E(a0)	; modify frame duration
00014142 1228 0022                  		move.b	$22(a0),d1
00014146 0201 0001                  		andi.b	#1,d1
0001414A 0228 00FC 0001             		andi.b	#$FC,1(a0)
00014150 8328 0001                  		or.b	d1,1(a0)
00014154 6000 FEF8                  		bra.w	SAnim_Do2
00014158                            ; ===========================================================================
00014158                            
00014158                            SAnim_Push:				; XREF: SAnim_RollJump
00014158 3428 0014                  		move.w	$14(a0),d2	; get Sonic's speed
0001415C 6B00                       		bmi.s	loc_13B1E
0001415E 4442                       		neg.w	d2
00014160                            
00014160                            loc_13B1E:
00014160 0642 0800                  		addi.w	#$800,d2
00014164 6A00                       		bpl.s	loc_13B26
00014166 7400                       		moveq	#0,d2
00014168                            
00014168                            loc_13B26:
00014168 EC4A                       		lsr.w	#6,d2
0001416A 1142 001E                  		move.b	d2,$1E(a0)	; modify frame duration
0001416E 43F9 0000 0000             		lea	(SonAni_Push).l,a1
00014174 1228 0022                  		move.b	$22(a0),d1
00014178 0201 0001                  		andi.b	#1,d1
0001417C 0228 00FC 0001             		andi.b	#$FC,1(a0)
00014182 8328 0001                  		or.b	d1,1(a0)
00014186 6000 FEC6                  		bra.w	SAnim_Do2
0001418A                            ; End of function Sonic_Animate
