00014290                            ; Sonic	pattern	loading	subroutine
00014290                            ; ---------------------------------------------------------------------------
00014290                            
00014290                            ; ||||||||||||||| S U B	R O U T	I N E |||||||||||||||||||||||||||||||||||||||
00014290                            
00014290                            
00014290                            LoadSonicDynPLC:			; XREF: Obj01_Control; et al
00014290 7000                       		moveq	#0,d0
00014292 1028 001A                  		move.b	$1A(a0),d0	 ; load frame number
00014296 B038 F766                  		cmp.b	($FFFFF766).w,d0 ; has Sonic frame changed?
0001429A 6700                       		beq.s	locret_13C96	 ; if not, branch
0001429C 11C0 F766                  		move.b	d0,($FFFFF766).w ; update frame number
000142A0 45F9 0000 0000             		lea	(SonicDynPLC).l,a2
000142A6 D040                       		add.w	d0,d0
000142A8 D4F2 0000                  		adda.w	(a2,d0.w),a2
000142AC 7A00                       		moveq	#0,d5
000142AE 1A1A                       		move.b	(a2)+,d5
000142B0 5345                       		subq.w	#1,d5
000142B2 6B00                       		bmi.s	locret_13C96
000142B4 383C F000                  		move.w	#$F000,d4
000142B8 2C3C 0000 0000             		move.l	#Art_Sonic,d6
000142BE                             
000142BE                            SPLC_ReadEntry:
000142BE 7200                       		moveq	#0,d1
000142C0 121A                       		move.b	(a2)+,d1
000142C2 E149                       		lsl.w	#8,d1
000142C4 121A                       		move.b	(a2)+,d1
000142C6 3601                       		move.w	d1,d3
000142C8 E04B                       		lsr.w	#8,d3
000142CA 0243 00F0                  		andi.w	#$F0,d3
000142CE 0643 0010                  		addi.w	#$10,d3
000142D2 0241 0FFF                  		andi.w	#$FFF,d1
000142D6 EB89                       		lsl.l	#5,d1
000142D8 D286                       		add.l	d6,d1
000142DA 3404                       		move.w	d4,d2
000142DC D843                       		add.w	d3,d4
000142DE D843                       		add.w	d3,d4
000142E0 4EB9 0000 1362             		jsr	(QueueDMATransfer).l
000142E6 51CD FFD6                  		dbf	d5,SPLC_ReadEntry	; repeat for number of entries
000142EA                             
000142EA                            locret_13C96:
000142EA 4E75                       		rts	
