0001401E                            Sonic_Animate:				; XREF: Obj01_Control; et al
0001401E 43F9 0000 0000             		lea	(SonicAniData).l,a1
00014024 7000                       		moveq	#0,d0
00014026 1028 001C                  		move.b	$1C(a0),d0
