00013964 D241                       		add.w	d1,d1
00013966 4A38 FE2E                  		tst.b   ($FFFFFE2E).w 		; test for speed shoes
0001396A 6700                       		beq.s	@noshoes
0001396C E242                       		asr.w	#1,d2
0001396E 9242                       		sub.w	d2,d1
00013970                            
00013970                            @noshoes:
00013970 0668 0064 0014             		addi.w	#$64,$14(a0)		; increment speed
