0000D37E                            ObjectsLoad:				; XREF: TitleScreen; et al
0000D37E 41F8 D000                  		lea	($FFFFD000).w,a0 ; load object RAM
0000D382 7E7F                       		moveq	#$7F,d7
0000D384 7000                       		moveq	#0,d0
0000D386 0C38 0006 D024             		cmpi.b	#6,($FFFFD024).w ; is Sonic Dying (primary routine >= 6)?
0000D38C 6400                       		bcc.s	ObjectsFreeze	; if yes, branch
0000D38E                            
0000D38E                            ExecuteObjects:
0000D38E 1010                       		move.b	(a0),d0		; load object's id
0000D390 6700                       		beq.s	@NextObject	; if it's zero, skip
0000D392 D040                       		add.w	d0,d0
0000D394 D040                       		add.w	d0,d0
0000D396 227B 0000                  		movea.l	Obj_Index-4(pc,d0.w),a1
0000D39A 4E91                       		jsr	(a1)		; run the object's code
0000D39C 7000                       		moveq	#0,d0
0000D39E                            
0000D39E                            @NextObject:
0000D39E 41E8 0040                  		lea	$40(a0),a0	; next object
0000D3A2 51CF FFEA                  		dbf	d7,ExecuteObjects
0000D3A6 4E75                       		rts
