00006FC0 4238 FE30                  		clr.b	($FFFFFE30).w
00006FC4 11FC 0001 F7C8             		move.b	#1,($FFFFF7C8).w	; freeze Sonic
00006FCA 45F9 0000 0000             		lea	LevelOrder,a2		; load level order array
00006FD0 302A 000E                  		move.w	$E(a2),d0
00006FD4 6700                       		beq.s	@GotoSegaScreen
00006FD6 31C0 FE10                  		move.w	d0,($FFFFFE10).w	; set next level according level order
00006FDA 31FC 0001 FE02             		move.w	#1,($FFFFFE02).w	; set restart level flag
00006FE0 4E75                       		rts
