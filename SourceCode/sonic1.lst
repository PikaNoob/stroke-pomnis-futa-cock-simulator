00001D8C                            Pal_DecColor:				; XREF: Pal_FadeOut
00001D8C 3A10                       		move.w	(a0),d5					; MJ: load colour
00001D8E 3205                       		move.w	d5,d1					; MJ: copy to d1
00001D90 1401                       		move.b	d1,d2					; MJ: load green and red
00001D92 1601                       		move.b	d1,d3					; MJ: load red
00001D94 0241 0E00                  		andi.w	#$0E00,d1				; MJ: get only blue
00001D98 6700 0000                  		beq	FCO_NoBlue				; MJ: if blue is finished, branch
00001D9C 0445 0200                  		subi.w	#$0200,d5				; MJ: decrease blue
00001DA0                            
00001DA0                            FCO_NoBlue:
00001DA0 0242 00E0                  		andi.w	#$00E0,d2				; MJ: get only green (needs to be word)
00001DA4 6700 0000                  		beq	FCO_NoGreen				; MJ: if green is finished, branch
00001DA8 0405 0020                  		subi.b	#$20,d5					; MJ: decrease green
00001DAC                            
00001DAC                            FCO_NoGreen:
00001DAC 0203 000E                  		andi.b	#$0E,d3					; MJ: get only red
00001DB0 6700 0000                  		beq	FCO_NoRed				; MJ: if red is finished, branch
00001DB4 5505                       		subq.b	#$02,d5					; MJ: decrease red
00001DB6                            
00001DB6                            FCO_NoRed:
00001DB6 30C5                       		move.w	d5,(a0)+				; MJ: save new colour
00001DB8 4E75                       		rts						; MJ: return
