00001C82                            Pal_FadeTo:
00001C82 31FC 003F F626             		move.w	#$3F,($FFFFF626).w
00001C88                            
00001C88                            Pal_FadeTo2:
00001C88 7000                       		moveq	#0,d0
00001C8A 41F8 FB00                  		lea	($FFFFFB00).w,a0
00001C8E 1038 F626                  		move.b	($FFFFF626).w,d0
00001C92 D0C0                       		adda.w	d0,a0
00001C94 7200                       		moveq	#0,d1
00001C96 1038 F627                  		move.b	($FFFFF627).w,d0
00001C9A                            
00001C9A                            Pal_ToBlack:
00001C9A 30C1                       		move.w	d1,(a0)+
00001C9C 51C8 FFFC                  		dbf	d0,Pal_ToBlack	; fill pallet with $000	(black)
00001CA0 780E                       		moveq	#$0E,d4					; MJ: prepare maximum colour check
00001CA2 7C00                       		moveq	#$00,d6					; MJ: clear d6
00001CA4                            
00001CA4                            loc_1DCE:
00001CA4 6100 F812                  		bsr.w	RunPLC_RAM
00001CA8 11FC 0012 F62A             		move.b	#$12,($FFFFF62A).w
00001CAE 6100 0000                  		bsr.w	DelayProgram
00001CB2 0846 0000                  		bchg	#$00,d6					; MJ: change delay counter
00001CB6 67EC                       		beq	loc_1DCE				; MJ: if null, delay a frame
00001CB8 6100                       		bsr.s	Pal_FadeIn
00001CBA 5504                       		subq.b	#$02,d4					; MJ: decrease colour check
00001CBC 66E6                       		bne	loc_1DCE				; MJ: if it has not reached null, branch
00001CBE 11FC 0012 F62A             		move.b	#$12,($FFFFF62A).w			; MJ: wait for V-blank again (so colours transfer)
00001CC4 6000 0000                  		bra	DelayProgram				; MJ: ''
00001CC8                            
00001CC8                            ; End of function Pal_FadeTo
