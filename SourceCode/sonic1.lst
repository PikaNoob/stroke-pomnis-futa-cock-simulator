0001CE06 7200                       		moveq	#0,d1
0001CE08 3238 F7D2                  		move.w	($FFFFF7D2).w,d1 ; load	time bonus
0001CE0C 6100 0000                  		bsr.w	Hud_TimeRingBonus
0001CE10 7200                       		moveq	#0,d1
0001CE12 3238 F7D4                  		move.w	($FFFFF7D4).w,d1 ; load	ring bonus
0001CE16 6100 0000                  		bsr.w	Hud_TimeRingBonus
0001CE1A                            
