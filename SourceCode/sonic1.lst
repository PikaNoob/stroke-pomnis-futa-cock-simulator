00001DBA                            Pal_MakeWhite: ; XREF: SpecialStage
00001DBA 31FC 003F F626                     move.w #$3F,($FFFFF626).w
00001DC0 7000                               moveq #0,d0
00001DC2 41F8 FB00                          lea ($FFFFFB00).w,a0
00001DC6 1038 F626                          move.b ($FFFFF626).w,d0
00001DCA D0C0                               adda.w d0,a0
00001DCC 323C 0EEE                          move.w #$EEE,d1
00001DD0 1038 F627                          move.b ($FFFFF627).w,d0
00001DD4                            
00001DD4                            PalWhite_Loop:
00001DD4 30C1                               move.w d1,(a0)+
00001DD6 51C8 FFFC                          dbf d0,PalWhite_Loop ; fill pallet with $000 (black)
00001DDA 780E                               moveq #$0E,d4 ; MJ: prepare maximum colour check
00001DDC 7C00                               moveq #$00,d6 ; MJ: clear d6
00001DDE                            
00001DDE                            loc_1EF4:
00001DDE 6100 F6D8                          bsr.w RunPLC_RAM
00001DE2 11FC 0012 F62A                     move.b #$12,($FFFFF62A).w
00001DE8 6100 0000                          bsr.w DelayProgram
00001DEC 0846 0000                          bchg #$00,d6 ; MJ: change delay counter
00001DF0 67EC                               beq loc_1EF4 ; MJ: if null, delay a frame
00001DF2 6100                               bsr.s Pal_WhiteToBlack
00001DF4 5504                               subq.b #$02,d4 ; MJ: decrease colour check
00001DF6 66E6                               bne loc_1EF4 ; MJ: if it has not reached null, branch
00001DF8 11FC 0012 F62A                     move.b #$12,($FFFFF62A).w ; MJ: wait for V-blank again (so colours transfer)
00001DFE 6000 0000                          bra DelayProgram ; MJ: ''
