000031DE                            
000031DE                            LevSel_Ending:				; XREF: LevelSelect
000031DE 11FC 0018 F600             		move.b	#$18,($FFFFF600).w ; set screen	mode to	$18 (Ending)
000031E4 31FC 0600 FE10             		move.w	#$600,($FFFFFE10).w ; set level	to 0600	(Ending)
000031EA 4E75                       		rts	
000031EC                            ; ===========================================================================
000031EC                            
000031EC                            LevSel_Credits:				; XREF: LevelSelect
