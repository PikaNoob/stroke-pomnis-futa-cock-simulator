00001F84 1038 F626                          move.b ($FFFFF626).w,d0
00001F88 D0C0                               adda.w d0,a0
00001F8A 1038 F627                          move.b ($FFFFF627).w,d0
00001F8E                            
00001F8E                            loc_1FAC:
00001F8E 6100                               bsr.s Pal_AddColor2
00001F90 51C8 FFFC                          dbf d0,loc_1FAC
00001F94                            
00001F94 7000                               moveq #0,d0
00001F96 41F8 FA80                          lea ($FFFFFA80).w,a0
00001F9A 1038 F626                          move.b ($FFFFF626).w,d0
00001F9E D0C0                               adda.w d0,a0
00001FA0 1038 F627                          move.b ($FFFFF627).w,d0
00001FA4                            
