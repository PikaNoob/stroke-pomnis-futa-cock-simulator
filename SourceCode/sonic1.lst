00001E44                            Pal_DecColor2: ; XREF: Pal_WhiteToBlack
00001E44 1A11                               move.b (a1),d5 ; MJ: load blue
00001E46 3219                               move.w (a1)+,d1 ; MJ: load green and red
00001E48 1401                               move.b d1,d2 ; MJ: load red
00001E4A E809                               lsr.b #$04,d1 ; MJ: get only green
00001E4C 0202 000E                          andi.b #$0E,d2 ; MJ: get only red
00001E50 3610                               move.w (a0),d3 ; MJ: load current colour in buffer
00001E52 B805                               cmp.b d5,d4 ; MJ: is it time for blue to fade?
00001E54 6300 0000                          bls FCI2_NoBlue ; MJ: if not, branch
00001E58 0443 0200                          subi.w #$0200,d3 ; MJ: dencrease blue
00001E5C                            
00001E5C                            FCI2_NoBlue:
