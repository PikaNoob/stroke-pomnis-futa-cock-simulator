000139C6                            Sonic_SpinDash:
000139C6 4A28 0039                  		tst.b	$39(a0)			; already Spin Dashing?
000139CA 6600                       		bne.s	loc2_1AC8E		; if set, branch
000139CC 0C28 0008 001C             		cmpi.b	#8,$1C(a0)		; is anim duck
000139D2 6600                       		bne.s	locret2_1AC8C		; if not, return
000139D4 1038 F603                  		move.b	($FFFFF603).w,d0	; read controller
000139D8 0200 0070                  		andi.b	#$70,d0			; pressing A/B/C ?
000139DC 6700 0000                  		beq.w	locret2_1AC8C		; if not, return
000139E0 117C 001F 001C             		move.b	#$1F,$1C(a0)		; set Spin Dash anim (9 in s2)
000139E6 303C 00D1                  		move.w	#$D1,d0			; spin sound ($E0 in s2)
000139EA 4EB9 0000 12C4             		jsr	(PlaySound_Special).l	; play spin sound
