0001CD5A                            ; Subroutine to	update the HUD
0001CD5A                            ; ---------------------------------------------------------------------------
0001CD5A                            
0001CD5A                            ; ||||||||||||||| S U B	R O U T	I N E |||||||||||||||||||||||||||||||||||||||
0001CD5A                            
0001CD5A                            
0001CD5A                            HudUpdate:
0001CD5A 4DF9 00C0 0000             		lea	($C00000).l,a6
0001CD60 4A78 FFFA                  		tst.w	($FFFFFFFA).w	; is debug mode	on?
0001CD64 6600 0000                  		bne.w	HudDebug	; if yes, branch
0001CD68 4A38 FE1F                  		tst.b	($FFFFFE1F).w	; does the score need updating?
0001CD6C 6700                       		beq.s	Hud_ChkRings	; if not, branch
0001CD6E 4238 FE1F                  		clr.b	($FFFFFE1F).w
0001CD78 2238 FE26                  		move.l	($FFFFFE26).w,d1 ; load	score
0001CD7C 6100 0000                  		bsr.w	Hud_Score
0001CD80                            
0001CD80                            Hud_ChkRings:
0001CD80 4A38 FE1D                  		tst.b	($FFFFFE1D).w	; does the ring	counter	need updating?
0001CD84 6700                       		beq.s	Hud_ChkTime	; if not, branch
0001CD86 6A00                       		bpl.s	loc_1C6E4
0001CD88 6100 0000                  		bsr.w	Hud_LoadZero
0001CD8C                            
0001CD8C                            loc_1C6E4:
0001CD8C 4238 FE1D                  		clr.b	($FFFFFE1D).w
0001CD96 7200                       		moveq	#0,d1
0001CD98 3238 FE20                  		move.w	($FFFFFE20).w,d1 ; load	number of rings
0001CD9C 6100 0000                  		bsr.w	Hud_Rings
0001CDA0                            
0001CDA0                            Hud_ChkTime:
0001CDA0 4A38 FE1E                  		tst.b	($FFFFFE1E).w	; is time counter locked?
0001CDA4 6700                       		beq.s	Hud_ChkLives	; if yes, branch
0001CDA6 4A78 F63A                  		tst.w	($FFFFF63A).w	; is the game paused?
0001CDAA 6600                       		bne.s	Hud_ChkLives	; if yes, branch
0001CDAC 43F8 FE22                  		lea	($FFFFFE22).w,a1; load time
0001CDB0 0C99 0009 3B3B             		cmpi.l	#$93B3B,(a1)+	; is the time 9.59?
0001CDB6 6700                       		beq.s	TimeOver	; if yes, branch
0001CDB8 5221                       		addq.b	#1,-(a1)	; add 1 to frame counter
0001CDBA 0C11 003C                  		cmpi.b	#60,(a1)	; have 60 frames (1 second) passed?
0001CDBE 6500                       		bcs.s	Hud_ChkLives	; if not, branch
0001CDC0 12BC 0000                  		move.b	#0,(a1)		; clear frame counter
0001CDC4 5221                       		addq.b	#1,-(a1)	; add 1 to seconds counter
0001CDC6 0C11 003C                  		cmpi.b	#60,(a1)	; have 60 seconds (1 minute) passed?
0001CDCA 6500                       		bcs.s	@RedrawCounter	; if not, branch
0001CDCC 12BC 0000                  		move.b	#0,(a1)		; clear seconds counter
0001CDD0 5221                       		addq.b	#1,-(a1)	; add 1 to minutes
0001CDD2 0C11 0009                  		cmpi.b	#9,(a1)		; have 9 minutes passed?
0001CDD6 6500                       		bcs.s	@RedrawCounter	; if not, branch
0001CDD8 12BC 0009                  		move.b	#9,(a1)		; set counter to 9 minutes
0001CDDC                            
0001CDDC                            ;loc_1C734:
0001CDDC                            @RedrawCounter:
0001CDE2 7200                       		moveq	#0,d1
0001CDE4 1238 FE23                  		move.b	($FFFFFE23).w,d1 ; load	minutes
0001CDE8 6100 0000                  		bsr.w	Hud_Mins
0001CDF2 7200                       		moveq	#0,d1
0001CDF4 1238 FE24                  		move.b	($FFFFFE24).w,d1 ; load	seconds
0001CDF8 6100 0000                  		bsr.w	Hud_Secs
0001CDFC                            
0001CDFC                            Hud_ChkLives:
0001CDFC 4A38 FE1C                  		tst.b	($FFFFFE1C).w	; does the lives counter need updating?
0001CE00 6700                       		beq.s	Hud_ChkBonus	; if not, branch
0001CE02 4238 FE1C                  		clr.b	($FFFFFE1C).w	; clear update live counter flag
0001CE06 6100 0000                  		bsr.w	Hud_Lives
0001CE0A                            
0001CE0A                            Hud_ChkBonus:
0001CE0A 4A38 F7D6                  		tst.b	($FFFFF7D6).w	; do time/ring bonus counters need updating?
0001CE0E 6700                       		beq.s	Hud_End		; if not, branch
0001CE10 4238 F7D6                  		clr.b	($FFFFF7D6).w
0001CE1E 7200                       		moveq	#0,d1
0001CE20 3238 F7D2                  		move.w	($FFFFF7D2).w,d1 ; load	time bonus
0001CE24 6100 0000                  		bsr.w	Hud_TimeRingBonus
0001CE28 7200                       		moveq	#0,d1
0001CE2A 3238 F7D4                  		move.w	($FFFFF7D4).w,d1 ; load	ring bonus
0001CE2E 6100 0000                  		bsr.w	Hud_TimeRingBonus
0001CE32                            
0001CE32                            Hud_End:
0001CE32 4E75                       		rts	
0001CE34                            ; ===========================================================================
0001CE34                            
0001CE34                            TimeOver:				; XREF: Hud_ChkTime
0001CE34 4238 FE1E                  		clr.b	($FFFFFE1E).w	; freeze time counter
0001CE38 41F8 D000                  		lea	($FFFFD000).w,a0
0001CE3C 2448                       		movea.l	a0,a2
0001CE3E 6100 E8B0                  		bsr.w	KillSonic
0001CE42 11FC 0001 FE1A             		move.b	#1,($FFFFFE1A).w
0001CE48 4E75                       		rts	
