00001FAC                            Pal_AddColor2: ; XREF: Pal_ToWhite
00001FAC 3A10                               move.w (a0),d5 ; MJ: load colour
00001FAE 0C45 0EEE                          cmpi.w #$EEE,d5
00001FB2 6700                               beq.s FCO2_NoRed
00001FB4 3205                               move.w d5,d1 ; MJ: copy to d1
00001FB6 1401                               move.b d1,d2 ; MJ: load green and red
00001FB8 1601                               move.b d1,d3 ; MJ: load red
00001FBA 0241 0E00                          andi.w #$0E00,d1 ; MJ: get only blue
00001FBE 0C41 0E00                          cmpi.w #$0E00,d1
00001FC2 6700 0000                          beq FCO2_NoBlue ; MJ: if blue is finished, branch
00001FC6 0645 0200                          addi.w #$0200,d5 ; MJ: increase blue
00001FCA                            
00001FCA                            FCO2_NoBlue:
00001FCA 0242 00E0                          andi.w #$00E0,d2 ; MJ: get only green (needs to be word)
00001FCE 0C42 00E0                          cmpi.w #$00E0,d2
00001FD2 6700 0000                          beq FCO2_NoGreen ; MJ: if green is finished, branch
00001FD6 0605 0020                          addi.b #$20,d5 ; MJ: increase green
00001FDA                            
00001FDA                            FCO2_NoGreen:
00001FDA 0203 000E                          andi.b #$0E,d3 ; MJ: get only red
00001FDE 0C03 000E                          cmpi.b #$0E,d3
00001FE2 6700 0000                          beq FCO2_NoRed ; MJ: if red is finished, branch
00001FE6 5405                               addq.b #$02,d5 ; MJ: increase red
00001FE8                            
00001FE8                            FCO2_NoRed:
00001FE8 30C5                               move.w d5,(a0)+ ; MJ: save new colour
00001FEA 4E75                               rts ; MJ: return
00001FEC                            ; End of function Pal_AddColor2
