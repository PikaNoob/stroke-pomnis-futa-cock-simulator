000029A6 D280                       		add.l	d0,d1
000029A8 E781                       		asl.l	#3,d1
000029AA D280                       		add.l	d0,d1
000029AC 3001                       		move.w	d1,d0
000029AE 4841                       		swap	d1
000029B0 D041                       		add.w	d1,d0
000029B2 3200                       		move.w	d0,d1
000029B4 4841                       		swap	d1
000029B6 21C1 F636                  		move.l	d1,($FFFFF636).w
