0000D52E                            ; ---------------------------------------------------------------------------
0000D52E                            ; Subroutine translating object	speed to update	object position
0000D52E                            ; ---------------------------------------------------------------------------
0000D52E                            
0000D52E                            ; ||||||||||||||| S U B	R O U T	I N E |||||||||||||||||||||||||||||||||||||||
0000D52E                            
0000D52E                            SpeedToPos:
0000D52E 3028 0010                  		move.w	$10(a0),d0	; load horizontal speed
0000D532 48C0                       		ext.l	d0
0000D534 E188                       		lsl.l	#8,d0		; multiply speed by $100
0000D536 D1A8 0008                  		add.l	d0,8(a0)	; add to x-axis	position
0000D53A 3028 0012                  		move.w	$12(a0),d0	; load vertical	speed
0000D53E 48C0                       		ext.l	d0
0000D540 E188                       		lsl.l	#8,d0		; multiply by $100
0000D542 D1A8 000C                  		add.l	d0,$C(a0)	; add to y-axis	position
0000D546 4E75                       		rts	
