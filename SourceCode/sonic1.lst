0001CD5C 41F8 D000                  		lea	($FFFFD000).w,a0
0001CD60 2448                       		movea.l	a0,a2
0001CD62 6100 E8B0                  		bsr.w	KillSonic
0001CD66 11FC 0001 FE1A             		move.b	#1,($FFFFFE1A).w
0001CD6C 4E75                       		rts	
