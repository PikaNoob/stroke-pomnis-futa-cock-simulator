0000128A 1003                       		move.b	d3,d0
0000128C 32C0                       		move.w	d0,(a1)+ ; store command
0000128E                             
0000128E 303C 9400                  		move.w	#$9400,d0 ; command to specify DMA transfer length & $FF00
00001292 E04B                       		lsr.w	#8,d3
00001294 1003                       		move.b	d3,d0
00001296 32C0                       		move.w	d0,(a1)+ ; store command
00001298                             
00001298 303C 9500                  		move.w	#$9500,d0 ; command to specify source address & $0001FE
0000129C E289                       		lsr.l	#1,d1
0000129E 1001                       		move.b	d1,d0
000012A0 32C0                       		move.w	d0,(a1)+ ; store command
000012A2                             
000012A2 303C 9600                  		move.w	#$9600,d0 ; command to specify source address & $01FE00
000012A6 E089                       		lsr.l	#8,d1
000012A8 1001                       		move.b	d1,d0
000012AA 32C0                       		move.w	d0,(a1)+ ; store command
000012AC                             
000012AC 303C 9700                  		move.w	#$9700,d0 ; command to specify source address & $FE0000
000012B0 E089                       		lsr.l	#8,d1
000012B2 1001                       		move.b	d1,d0
000012B4 32C0                       		move.w	d0,(a1)+ ; store command
