00003358                            ; ---------------------------------------------------------------------------
00003358                            ; Subroutine to	change what you're selecting in the level select
00003358                            ; ---------------------------------------------------------------------------
00003358                            
00003358                            ; ||||||||||||||| S U B	R O U T	I N E |||||||||||||||||||||||||||||||||||||||
00003358                            
00003358                            
00003358                            LevSelControls:				; XREF: LevelSelect
00003358 1238 F605                  		move.b	(Joypad|Press),d1
0000335C 0201 0003                  		andi.b	#Up+Down,d1	; is up/down held?
00003360 6600                       		bne.s	LevSel_UpDown	; if yes, branch
00003362 5378 FF80                  		subq.w	#1,($FFFFFF80).w ; subtract 1 from time	until next move
00003366 6A00                       		bpl.s	LevSel_SndTest	; if time remains, branch
00003368                            
00003368                            LevSel_UpDown:
00003368 31FC 000B FF80             		move.w	#$B,($FFFFFF80).w ; reset time delay
0000336E 1238 F604                  		move.b	(Joypad|Held),d1
00003372 0201 0003                  		andi.b	#Up+Down,d1	; is up/down held?
00003376 6700                       		beq.s	LevSel_SndTest	; if not, branch
00003378 3038 FF82                  		move.w	($FFFFFF82).w,d0
0000337C 0801 0000                  		btst	#iUp,d1		; is up	held?
00003380 6700                       		beq.s	LevSel_Down	; if not, branch
00003382 5340                       		subq.w	#1,d0		; move up 1 selection
00003384 6400                       		bcc.s	LevSel_Down
00003386 7014                       		moveq	#$14,d0		; if selection moves below 0, jump to selection	$14
00003388                            
00003388                            LevSel_Down:
00003388 0801 0001                  		btst	#iDown,d1	; is down held?
0000338C 6700                       		beq.s	LevSel_Refresh	; if not, branch
0000338E 5240                       		addq.w	#1,d0		; move down 1 selection
00003390 0C40 0015                  		cmpi.w	#$15,d0
00003394 6500                       		bcs.s	LevSel_Refresh
00003396 7000                       		moveq	#0,d0		; if selection moves above $14,	jump to	selection 0
00003398                            
00003398                            LevSel_Refresh:
00003398 31C0 FF82                  		move.w	d0,($FFFFFF82).w ; set new selection
0000339C 6100 0000                  		bsr.w	LevSelTextLoad	; refresh text
000033A0 4E75                       		rts	
000033A2                            ; ===========================================================================
000033A2                            
000033A2                            LevSel_SndTest:				; XREF: LevSelControls
000033A2 0C78 0014 FF82             		cmpi.w	#$14,($FFFFFF82).w ; is	item $14 selected?
000033A8 6600                       		bne.s	LevSel_NoMove	; if not, branch
000033AA 1238 F605                  		move.b	(Joypad|Press),d1
000033AE 0201 000C                  		andi.b	#Left+Right,d1	; is left/right	pressed?
000033B2 6700                       		beq.s	LevSel_NoMove	; if not, branch
000033B4 3038 FF84                  		move.w	($FFFFFF84).w,d0
000033B8 0801 0002                  		btst	#iLeft,d1	; is left pressed?
000033BC 6700                       		beq.s	LevSel_Right	; if not, branch
000033BE 5340                       		subq.w	#1,d0		; subtract 1 from sound	test
000033C0 6400                       		bcc.s	LevSel_Right
000033C2 704F                       		moveq	#$4F,d0		; if sound test	moves below 0, set to $4F
000033C4                            
000033C4                            LevSel_Right:
000033C4 0801 0003                  		btst	#iRight,d1	; is right pressed?
000033C8 6700                       		beq.s	LevSel_Refresh2	; if not, branch
000033CA 5240                       		addq.w	#1,d0		; add 1	to sound test
000033CC 0C40 0050                  		cmpi.w	#$50,d0
000033D0 6500                       		bcs.s	LevSel_Refresh2
000033D2 7000                       		moveq	#0,d0		; if sound test	moves above $4F, set to	0
000033D4                            
000033D4                            LevSel_Refresh2:
000033D4 31C0 FF84                  		move.w	d0,($FFFFFF84).w ; set sound test number
000033D8 6100 0000                  		bsr.w	LevSelTextLoad	; refresh text
000033DC                            
000033DC                            LevSel_NoMove:
000033DC 4E75                       		rts	
000033DE                            ; End of function LevSelControls
