000013CC 6700                       		beq.s	ProcessDMAQueue_Done ; branch if we reached a stop token
000013CE 3A80                       		move.w	d0,(a5)		; transfer length
000013D0 3A99                       		move.w	(a1)+,(a5)	; transfer length
000013D2 3A99                       		move.w	(a1)+,(a5)	; source address
000013D4 3A99                       		move.w	(a1)+,(a5)	; source address
000013D6 3A99                       		move.w	(a1)+,(a5)	; source address
000013D8 3A99                       		move.w	(a1)+,(a5)	; destination
000013DA 3A99                       		move.w	(a1)+,(a5)	; destination
000013DC B2FC C8FC                  		cmpa.w	#$C8FC,a1
000013E0 66E8                       		bne.s	ProcessDMAQueue_Loop ; loop if we haven't reached the end of the buffer
000013E2                            
