00003272                            ; Level	select - level pointers
00003272                            ; ---------------------------------------------------------------------------
00003272                            ; Vladikcomper: Pointers were converted from bin to asm format for
00003272                            ;		more convenient editing.
00003272                            LSelectPointers:
00003272                            		include	"_inc\Level select pointers.asm"
00003272                            ; ===========================================================================
00003272                            ; *              S1HS - Levels order in Level Select Menu                   *
00003272                            ; ===========================================================================
00003272                            ; This file stores level order in level select menu
00003272                            ; The format of each item is: ZZAA, where ZZ is zone and AA is act number.
00003272                            ; ===========================================================================
00003272                            
00003272 0000                       		dc.w	$0000	; GHZ 1
00003274 0001                       		dc.w	$0001	; GHZ 2
00003276 0002                       		dc.w	$0002	; GHZ 3
00003278                            
00003278 0100                       		dc.w	$0100	; LZ 1
0000327A 0101                       		dc.w	$0101	; LZ 2
0000327C 0102                       		dc.w	$0102	; LZ 3
0000327E                            
0000327E 0200                       		dc.w	$0200	; MZ 1
00003280 0201                       		dc.w	$0201	; MZ 2
00003282 0202                       		dc.w	$0202	; MZ 3
00003284                            
00003284 0300                       		dc.w	$0300	; SLZ 1
00003286 0301                       		dc.w	$0301	; SLZ 2
00003288 0302                       		dc.w	$0302	; SLZ 3
0000328A                            
0000328A 0400                       		dc.w	$0400	; SYZ 1
0000328C 0401                       		dc.w	$0401	; SYZ 2
0000328E 0402                       		dc.w	$0402	; SYZ 3
00003290                            
00003290 0500                       		dc.w	$0500	; SBZ 1
00003292 0501                       		dc.w	$0501	; SBZ 2
00003294 0103                       		dc.w	$0103	; SBZ 3 (actually LZ 4)
00003296                            
00003296 0502                       		dc.w	$0502	; Final Zone (actually SBZ 3)
00003298                            
00003298 0700                       		dc.w	$0700	; Special Stage
0000329A 8000                       		dc.w	$8000	; Sound select
0000329A 8000                       		dc.w	$8000	; Sound select
0000329C                            		even
