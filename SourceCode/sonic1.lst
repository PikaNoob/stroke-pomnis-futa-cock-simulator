0000D3A8                            ; ===========================================================================
0000D3A8                            ; ---------------------------------------------------------------------------
0000D3A8                            ; Just displays objects without running their code
0000D3A8                            ; Runs if Sonic is in dying state
0000D3A8                            ; ---------------------------------------------------------------------------
0000D3A8                            
0000D3A8                            ;loc_D362:
0000D3A8                            ObjectsFreeze:
0000D3A8 7E1F                       		moveq	#$1F,d7
0000D3AA 61E2                       		bsr.s	ExecuteObjects	; run code only for reserved object SST
0000D3AC 7E5F                       		moveq	#$5F,d7
0000D3AE                            
0000D3AE                            DisplayObjects:
0000D3AE 7000                       		moveq	#0,d0
0000D3B0 1010                       		move.b	(a0),d0		; load object's id
0000D3B2 6700                       		beq.s	@NextObject	; if it's zero, branch
0000D3B4 4A28 0001                  		tst.b	1(a0)		; test render flag
0000D3B8 6A00                       		bpl.s	@NextObject	; if bit #7 isn't set, branch
0000D3BA 6100 0000                  		bsr.w	DisplaySprite
0000D3BE                            
0000D3BE                            @NextObject:
0000D3BE 41E8 0040                  		lea	$40(a0),a0	; next object
0000D3C2 51CF FFEA                  		dbf	d7,DisplayObjects
0000D3C6 4E75                       		rts
