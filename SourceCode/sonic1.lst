0000298A                            DelayProgram:				; XREF: PauseGame
0000298A 46FC 2300                  		move	#$2300,sr	; disable interrupts
0000298E 4A38 F62A                  	@wait:	tst.b	($FFFFF62A).w	; has VBlank routine finished?
00002992 66FA                       		bne.s	@wait		; if not, branch
00002994 4E75                       		rts	
00002996                            ; End of function DelayProgram
