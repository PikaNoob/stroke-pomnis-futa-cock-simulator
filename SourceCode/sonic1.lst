0000D548                            ; ---------------------------------------------------------------------------
0000D548                            ; Subroutine to	display	a sprite/object, when a0 is the	object RAM
0000D548                            ; ---------------------------------------------------------------------------
0000D548                            
0000D548                            ; ||||||||||||||| S U B	R O U T	I N E |||||||||||||||||||||||||||||||||||||||
0000D548                            
0000D548                            
0000D548                            DisplaySprite:
0000D548 43F8 AC00                  		lea	($FFFFAC00).w,a1 ; load sprite table
0000D54C 3028 0018                  		move.w	$18(a0),d0	; load object's prioity and horizontal radius
0000D550 E248                       		lsr.w	#1,d0		; shift 1 bit right
0000D552 0240 0380                  		andi.w	#$380,d0	; apply bit mask to erase obj radius value
0000D556 D2C0                       		adda.w	d0,a1		; set sprite table destination, depending on priority
0000D558 0C51 007E                  		cmpi.w	#$7E,(a1)	; is sprite table overflowed?
0000D55C 6400                       		bcc.s	DisplaySprite_Rts ; if yes, branch
0000D55E 5451                       		addq.w	#2,(a1)
0000D560 D2D1                       		adda.w	(a1),a1		; load free slot in sprite table
0000D562 3288                       		move.w	a0,(a1)		; write obj address to that slot
0000D564                            
0000D564                            DisplaySprite_Rts:
0000D564 4E75                       		rts	
0000D566                            ; End of function DisplaySprite
0000D566                            
0000D566                            ; ---------------------------------------------------------------------------
0000D566                            ; Subroutine to	display	a 2nd sprite/object, when a1 is	the object RAM
