0001CD42                            HudUpdate:
0001CD42 4DF9 00C0 0000             		lea	($C00000).l,a6
0001CD48 4A78 FFFA                  		tst.w	($FFFFFFFA).w	; is debug mode	on?
0001CD4C 6600 0000                  		bne.w	HudDebug	; if yes, branch
0001CD50 4A38 FE1F                  		tst.b	($FFFFFE1F).w	; does the score need updating?
0001CD54 6700                       		beq.s	Hud_ChkRings	; if not, branch
0001CD56 4238 FE1F                  		clr.b	($FFFFFE1F).w
0001CD60 2238 FE26                  		move.l	($FFFFFE26).w,d1 ; load	score
0001CD64 6100 0000                  		bsr.w	Hud_Score
0001CD68                            
0001CD68                            Hud_ChkRings:
0001CD68 4A38 FE1D                  		tst.b	($FFFFFE1D).w	; does the ring	counter	need updating?
0001CD6C 6700                       		beq.s	Hud_ChkTime	; if not, branch
0001CD6E 6A00                       		bpl.s	loc_1C6E4
0001CD70 6100 0000                  		bsr.w	Hud_LoadZero
0001CD74                            
0001CD74                            loc_1C6E4:
0001CD74 4238 FE1D                  		clr.b	($FFFFFE1D).w
0001CD7E 7200                       		moveq	#0,d1
0001CD80 3238 FE20                  		move.w	($FFFFFE20).w,d1 ; load	number of rings
0001CD84 6100 0000                  		bsr.w	Hud_Rings
0001CD88                            
0001CD88                            Hud_ChkTime:
0001CD88 4A38 FE1E                  		tst.b	($FFFFFE1E).w	; is time counter locked?
0001CD8C 6700                       		beq.s	Hud_ChkLives	; if yes, branch
0001CD8E 4A78 F63A                  		tst.w	($FFFFF63A).w	; is the game paused?
0001CD92 6600                       		bne.s	Hud_ChkLives	; if yes, branch
0001CD94 43F8 FE22                  		lea	($FFFFFE22).w,a1; load time
0001CD98 0C99 0009 3B3B             		cmpi.l	#$93B3B,(a1)+	; is the time 9.59?
0001CD9E 6700                       		beq.s	TimeOver	; if yes, branch
0001CDA0 5221                       		addq.b	#1,-(a1)	; add 1 to frame counter
0001CDA2 0C11 003C                  		cmpi.b	#60,(a1)	; have 60 frames (1 second) passed?
0001CDA6 6500                       		bcs.s	Hud_ChkLives	; if not, branch
0001CDA8 12BC 0000                  		move.b	#0,(a1)		; clear frame counter
0001CDAC 5221                       		addq.b	#1,-(a1)	; add 1 to seconds counter
0001CDAE 0C11 003C                  		cmpi.b	#60,(a1)	; have 60 seconds (1 minute) passed?
0001CDB2 6500                       		bcs.s	@RedrawCounter	; if not, branch
0001CDB4 12BC 0000                  		move.b	#0,(a1)		; clear seconds counter
0001CDB8 5221                       		addq.b	#1,-(a1)	; add 1 to minutes
0001CDBA 0C11 0009                  		cmpi.b	#9,(a1)		; have 9 minutes passed?
0001CDBE 6500                       		bcs.s	@RedrawCounter	; if not, branch
0001CDC0 12BC 0009                  		move.b	#9,(a1)		; set counter to 9 minutes
0001CDC4                            
0001CDC4                            ;loc_1C734:
