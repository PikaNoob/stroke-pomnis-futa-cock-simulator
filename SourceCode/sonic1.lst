0000032C                            ;		bne.w	CheckSumError	; if they don't match, branch
0000032C 4DF8 FE00                  		lea	($FFFFFE00).w,a6
00000330 7E00                       		moveq	#0,d7
00000332 3C3C 007F                  		move.w	#$7F,d6
