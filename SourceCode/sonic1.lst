000028D6                            ; Subroutine to calculate sine and cosine
000028D6                            ; ===========================================================================
000028D6                            ; Input:	d0 - Angle (0-$FF)
000028D6                            ; Output:	d0 - Sine
000028D6                            ;		d1 - Cosine
000028D6                            ; ---------------------------------------------------------------------------
000028D6                            
000028D6                            CalcSine:
000028D6 0240 00FF                  		andi.w	#$FF,d0
000028DA D040                       		add.w	d0,d0
000028DC 0640 0080                  		addi.w	#$80,d0
000028E0 323B 0000                  		move.w	Sine_Data(pc,d0.w),d1	; get cosine
000028E4 0440 0080                  		subi.w	#$80,d0
000028E8 303B 0000                  		move.w	Sine_Data(pc,d0.w),d0	; get sine
000028EC 4E75                       		rts	
000028EE                            
