00001F5E 7807                               moveq #$07,d4 ; MJ: set repeat times
00001F60 7C00                               moveq #$00,d6 ; MJ: clear d6
00001F62                            
00001F62                            loc_1F86:
00001F62 6100 F63A                          bsr.w RunPLC_RAM
00001F66 11FC 0012 F62A                     move.b #$12,($FFFFF62A).w
00001F6C 6100 0000                          bsr.w DelayProgram
00001F70 0846 0000                          bchg #$00,d6 ; MJ: change delay counter
00001F74 67EC                               beq loc_1F86 ; MJ: if null, delay a frame
00001F76 6100                               bsr.s Pal_ToWhite
00001F78 51CC FFE8                          dbf d4,loc_1F86
00001F7C 4E75                               rts
