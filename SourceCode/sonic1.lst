00001532                            ; Subroutines to put PLC block into the queue
00001532                            ; ===========================================================================
00001532                            ; Note:		Queue can hold no more than 21 items
00001532                            ; Input:	d0 - PLC block index
00001532                            ; ---------------------------------------------------------------------------
00001532                            
00001532                            LoadPLC:
00001532 48E7 0060                  		movem.l	a1-a2,-(sp)	; move registers to the stack
00001536 43F9 0000 0000             		lea	(ArtLoadCues).l,a1
0000153C D040                       		add.w	d0,d0		; double block index
0000153E 3031 0000                  		move.w	(a1,d0.w),d0
00001542 43F1 0000                  		lea	(a1,d0.w),a1	 ; load PLC block to a1
00001546 45F8 F680                  		lea	($FFFFF680).w,a2 ; load PLC queue to a2
0000154A                            
0000154A                            @FindSlot:
0000154A 4A92                       		tst.l	(a2)		; is the slot in queue empty?
0000154C 6700                       		beq.s	@AddToQueue	; if yes, branch
0000154E 5C4A                       		addq.w	#6,a2		; next slot
00001550 60F8                       		bra.s	@FindSlot
00001552                            ; ===========================================================================
00001552                            
00001552                            @AddToQueue:
00001552 3019                       		move.w	(a1)+,d0	; move number of items in block to d0
00001554 6B00                       		bmi.s	LoadPLC_Rts	; if it's negative (>=$80), then something is wrong, exit
00001556                            
00001556                            @WriteCues:
