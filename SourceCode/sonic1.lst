0000A684                            ; ---------------------------------------------------------------------------
0000A684                            ; Subroutine to	animate	a sprite using an animation script
0000A684                            ; ---------------------------------------------------------------------------
0000A684                            
0000A684                            ; ||||||||||||||| S U B	R O U T	I N E |||||||||||||||||||||||||||||||||||||||
0000A684                            
0000A684                            
0000A684                            AnimateSprite:
0000A684 7000                       		moveq	#0,d0
0000A686 1028 001C                  		move.b	$1C(a0),d0	; move animation number	to d0
0000A68A B028 001D                  		cmp.b	$1D(a0),d0	; is animation set to restart?
0000A68E 6700                       		beq.s	Anim_Run	; if not, branch
0000A690 1140 001D                  		move.b	d0,$1D(a0)	; set to "no restart"
0000A694 117C 0000 001B             		move.b	#0,$1B(a0)	; reset	animation
0000A69A 117C 0000 001E             		move.b	#0,$1E(a0)	; reset	frame duration
0000A6A0                            
0000A6A0                            Anim_Run:
0000A6A0 5328 001E                  		subq.b	#1,$1E(a0)	; subtract 1 from frame	duration
0000A6A4 6A00                       		bpl.s	Anim_Wait	; if time remains, branch
0000A6A6 D040                       		add.w	d0,d0
0000A6A8 D2F1 0000                  		adda.w	(a1,d0.w),a1	; jump to appropriate animation	script
0000A6AC 1151 001E                  		move.b	(a1),$1E(a0)	; load frame duration
0000A6B0 7200                       		moveq	#0,d1
0000A6B2 1228 001B                  		move.b	$1B(a0),d1	; load current frame number
0000A6B6 1031 1001                  		move.b	1(a1,d1.w),d0	; read sprite number from script
0000A6BA 6B00                       		bmi.s	Anim_End_FF	; if animation is complete, branch
0000A6BC                            
0000A6BC                            Anim_Next:
0000A6BC 1200                       		move.b	d0,d1
0000A6BE 0200 001F                  		andi.b	#$1F,d0
0000A6C2 1140 001A                  		move.b	d0,$1A(a0)	; load sprite number
0000A6C6 1028 0022                  		move.b	$22(a0),d0
0000A6CA E719                       		rol.b	#3,d1
0000A6CC B101                       		eor.b	d0,d1
0000A6CE 0201 0003                  		andi.b	#3,d1
0000A6D2 0228 00FC 0001             		andi.b	#$FC,1(a0)
0000A6D8 8328 0001                  		or.b	d1,1(a0)
0000A6DC 5228 001B                  		addq.b	#1,$1B(a0)	; next frame number
0000A6E0                            
0000A6E0                            Anim_Wait:
0000A6E0 4E75                       		rts	
0000A6E2                            ; ===========================================================================
0000A6E2                            
0000A6E2                            Anim_End_FF:
0000A6E2 5200                       		addq.b	#1,d0		; is the end flag = $FF	?
0000A6E4 6600                       		bne.s	Anim_End_FE	; if not, branch
0000A6E6 117C 0000 001B             		move.b	#0,$1B(a0)	; restart the animation
0000A6EC 1029 0001                  		move.b	1(a1),d0	; read sprite number
0000A6F0 60CA                       		bra.s	Anim_Next
0000A6F2                            ; ===========================================================================
0000A6F2                            
0000A6F2                            Anim_End_FE:
0000A6F2 5200                       		addq.b	#1,d0		; is the end flag = $FE	?
0000A6F4 6600                       		bne.s	Anim_End_FD	; if not, branch
0000A6F6 1031 1002                  		move.b	2(a1,d1.w),d0	; read the next	byte in	the script
0000A6FA 9128 001B                  		sub.b	d0,$1B(a0)	; jump back d0 bytes in	the script
0000A6FE 9200                       		sub.b	d0,d1
0000A700 1031 1001                  		move.b	1(a1,d1.w),d0	; read sprite number
0000A704 60B6                       		bra.s	Anim_Next
0000A706                            ; ===========================================================================
0000A706                            
0000A706                            Anim_End_FD:
0000A706 5200                       		addq.b	#1,d0		; is the end flag = $FD	?
0000A708 6600                       		bne.s	Anim_End_FC	; if not, branch
0000A70A 1171 1002 001C             		move.b	2(a1,d1.w),$1C(a0) ; read next byte, run that animation
0000A710                            
0000A710                            Anim_End_FC:
0000A710 5200                       		addq.b	#1,d0		; is the end flag = $FC	?
0000A712 6600                       		bne.s	Anim_End_FB	; if not, branch
0000A714 5428 0024                  		addq.b	#2,$24(a0)	; jump to next routine
0000A718                            
0000A718                            Anim_End_FB:
0000A718 5200                       		addq.b	#1,d0		; is the end flag = $FB	?
0000A71A 6600                       		bne.s	Anim_End_FA	; if not, branch
0000A71C 117C 0000 001B             		move.b	#0,$1B(a0)	; reset	animation
0000A722 4228 0025                  		clr.b	$25(a0)		; reset	2nd routine counter
0000A726                            
0000A726                            Anim_End_FA:
0000A726 5200                       		addq.b	#1,d0		; is the end flag = $FA	?
0000A728 6600                       		bne.s	Anim_End	; if not, branch
0000A72A 5428 0025                  		addq.b	#2,$25(a0)	; jump to next routine
0000A72E                            
0000A72E                            Anim_End:
0000A72E 4E75                       		rts	
0000A730                            ; End of function AnimateSprite
