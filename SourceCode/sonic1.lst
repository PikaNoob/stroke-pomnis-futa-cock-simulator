0000D56A 3029 0018                  		move.w	$18(a1),d0	; load object's prioity and horizontal radius
0000D56E E248                       		lsr.w	#1,d0		; shift 1 bit right
0000D570 0240 0380                  		andi.w	#$380,d0	; apply bit mask to erase obj radius value
0000D574 D4C0                       		adda.w	d0,a2		; set sprite table destination, depending on priority
0000D576 0C52 007E                  		cmpi.w	#$7E,(a2)	; is sprite table overflowed?
0000D57A 6400                       		bcc.s	DisplaySprite2_Rts ; if yes, branch
0000D57C 5452                       		addq.w	#2,(a2)
0000D57E D4D2                       		adda.w	(a2),a2		; load free slot in sprite table
0000D580 3489                       		move.w	a1,(a2)		; write obj address to that slot
0000D582                            
0000D582                            DisplaySprite2_Rts:
0000D582 4E75                       		rts
0000D584                            ; End of function DisplaySprite2
