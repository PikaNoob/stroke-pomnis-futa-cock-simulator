0001CEA6 6100 0000                  		bsr.w	Hud_TimeRingBonus
0001CEAA 7200                       		moveq	#0,d1
0001CEAC 3238 F7D4                  		move.w	($FFFFF7D4).w,d1 ; load	ring bonus
0001CEB0 6100 0000                  		bsr.w	Hud_TimeRingBonus
