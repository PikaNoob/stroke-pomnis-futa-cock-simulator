00013A24 6600 0000                  		bne.w	loc2_1AD30		; if set, branch
00013A28 117C 000E 0016             		move.b	#$E,$16(a0)		; $16(a0) is height/2
00013A2E 117C 0007 0017             		move.b	#7,$17(a0)		; $17(a0) is width/2
