0001CC52                            AddPoints:
0001CC52 11FC 0001 FE1F             		move.b	#1,($FFFFFE1F).w ; set score counter to	update
0001CC58 45F8 FFC0                  		lea	($FFFFFFC0).w,a2
0001CC5C 47F8 FE26                  		lea	($FFFFFE26).w,a3
0001CC60 D193                       		add.l	d0,(a3)		; add d0*10 to the score
0001CC62 223C 000F 423F             		move.l	#999999,d1
0001CC68 B293                       		cmp.l	(a3),d1		; is #999999 higher than the score?
0001CC6A 6200 0000                  		bhi.w	loc_1C6AC	; if yes, branch
0001CC6E 2681                       		move.l	d1,(a3)		; reset	score to #999999
0001CC70 2481                       		move.l	d1,(a2)
