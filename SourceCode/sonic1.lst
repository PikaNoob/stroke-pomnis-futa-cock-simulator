0000D238                            ; Subroutine to	smash a	block (GHZ walls and MZ	blocks)
0000D238                            ; ---------------------------------------------------------------------------
0000D238                            
0000D238                            ; ||||||||||||||| S U B	R O U T	I N E |||||||||||||||||||||||||||||||||||||||
