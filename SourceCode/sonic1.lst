0001CE82 6700                       		beq.s	HudDb_ChkBonus	; if not, branch
0001CE84 4238 FE1C                  		clr.b	($FFFFFE1C).w	; clear update live counter flag
0001CE88 6100 0000                  		bsr.w	Hud_Lives
0001CE8C                            
0001CE8C                            HudDb_ChkBonus:
0001CE8C 4A38 F7D6                  		tst.b	($FFFFF7D6).w	; does the ring/time bonus counter need	updating?
0001CE90 6700                       		beq.s	HudDb_End	; if not, branch
0001CE92 4238 F7D6                  		clr.b	($FFFFF7D6).w
