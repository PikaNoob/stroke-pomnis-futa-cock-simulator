000138BC                            ; ||||||||||||||| S U B	R O U T	I N E |||||||||||||||||||||||||||||||||||||||
000138BC                            
000138BC                            ;SCDPeelout:
000138BC 0828 0001 0039             		btst	#1,$39(a0)
000138C2 6600                       		bne.s	SCDPeelout_Launch
000138C4 0C28 0007 001C             		cmpi.b	#7,$1C(a0) ;check to see if your looking up
000138CA 6600                       		bne.s	@return
000138CC 1038 F603                  		move.b	($FFFFF603).w,d0
000138D0 0200 0070                  		andi.b	#%01110000,d0
000138D4 6700 0000                  		beq.w	@return
000138D8 117C 0001 001C             		move.b	#1,$1C(a0)
000138DE 317C 0000 003A             		move.w	#0,$3A(a0)
000138E4 303C 00D2                  		move.w	#$D2,d0
000138E8 4EB9 0000 12C4             		jsr		(PlaySound_Special).l 	; Play peelout charge sound
000138EE                            	;	sfx 	sfx_PeeloutCharge 		; These are if you use AMPS
000138EE 588F                       		addq.l	#4,sp
000138F0 08E8 0001 0039             		bset	#1,$39(a0)
000138F6                            		
000138F6 4268 0014                  		clr.w	$14(a0)
000138FA                             
000138FA 6100 FDE4                  		bsr.w	Sonic_LevelBound
000138FE 6100 0000                  		bsr.w	Sonic_AnglePos
00013902                             
00013902                            	@return:
00013902 4E75                       		rts	
00013904                            ; ---------------------------------------------------------------------------
00013904                             
00013904                            SCDPeelout_Launch:
00013904 1038 F602                  		move.b	($FFFFF602).w,d0
00013908 0800 0000                  		btst	#0,d0
0001390C 6600 0000                  		bne.w	SCDPeelout_Charge
00013910 08A8 0001 0039             		bclr	#1,$39(a0)	; stop Dashing
00013916 0C28 001E 003A             		cmpi.b	#$1E,$3A(a0)	; have we been charging long enough?
0001391C 6600                       		bne.s	SCDPeelout_Stop_Sound
0001391E 117C 0000 001C             		move.b	#0,$1C(a0)	; launches here (peelout sprites)
00013924 317C 0001 0010             		move.w	#1,$10(a0)	; force X speed to nonzero for camera lag's benefit
0001392A 3028 0014                  		move.w	$14(a0),d0
0001392E 0440 0800                  		subi.w	#$800,d0
00013932 D040                       		add.w	d0,d0
00013934 0240 1F00                  		andi.w	#$1F00,d0
00013938 4440                       		neg.w	d0
0001393A 0640 2000                  		addi.w	#$2000,d0
0001393E                            		;move.w	d0,(v_cameralag).w
0001393E 0828 0000 0022             		btst	#0,$22(a0)
00013944 6700                       		beq.s	@dontflip
00013946 4468 0014                  		neg.w	$14(a0)
0001394A                             
