000012CE B2FC C8FC                  		cmpa.w	#$C8FC,a1
000012D2 6700                       		beq.s	QueueDMATransfer_Done ; return if there's no more room in the buffer
000012D4 32BC 0000                  		move.w	#0,(a1) ; put a stop token at the end of the used part of the buffer
000012D8                            
