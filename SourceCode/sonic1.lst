0000D238                            SmashObject:				; XREF: Obj3C_Smash
0000D238 7000                       		moveq	#0,d0
0000D23A 1028 001A                  		move.b	$1A(a0),d0
0000D23E D040                       		add.w	d0,d0
0000D240 2668 0004                  		movea.l	4(a0),a3
0000D244 D6F3 0000                  		adda.w	(a3,d0.w),a3
0000D248 524B                       		addq.w	#1,a3
0000D24A 08E8 0005 0001             		bset	#5,1(a0)
0000D250 1810                       		move.b	0(a0),d4
0000D252 1A28 0001                  		move.b	1(a0),d5
0000D256 2248                       		movea.l	a0,a1
0000D258 6000                       		bra.s	Smash_LoadFrag
