0000D1DC 0C40 0480                  		cmpi.w	#$480,d0	; is Sonic's speed $480 or higher?
0000D1E0 65E8                       		bcs.s	locret_D180	; if not, branch
0000D1E2 3368 0030 0010             		move.w	$30(a0),$10(a1)
0000D1E8 5869 0008                  		addq.w	#4,8(a1)
0000D1EC 49F9 0000 0000             		lea	(Obj3C_FragSpd1).l,a4 ;	use fragments that move	right
0000D1F2 3028 0008                  		move.w	8(a0),d0
0000D1F6 B069 0008                  		cmp.w	8(a1),d0	; is Sonic to the right	of the block?
0000D1FA 6500                       		bcs.s	Obj3C_Smash	; if yes, branch
0000D1FC 5169 0008                  		subq.w	#8,8(a1)
0000D200 49F9 0000 0000             		lea	(Obj3C_FragSpd2).l,a4 ;	use fragments that move	left
