000141DC 45F9 0000 0000             		lea	(SonicDynPLC).l,a2
000141E2 D040                       		add.w	d0,d0
000141E4 D4F2 0000                  		adda.w	(a2,d0.w),a2
000141E8 7A00                       		moveq	#0,d5
000141EA 1A1A                       		move.b	(a2)+,d5
000141EC 5345                       		subq.w	#1,d5
