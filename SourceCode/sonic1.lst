0001CC7E                            HudUpdate:
0001CC7E 4DF9 00C0 0000             		lea	($C00000).l,a6
0001CC84 4A78 FFFA                  		tst.w	($FFFFFFFA).w	; is debug mode	on?
0001CC88 6600 0000                  		bne.w	HudDebug	; if yes, branch
0001CC8C 4A38 FE1F                  		tst.b	($FFFFFE1F).w	; does the score need updating?
0001CC90 6700                       		beq.s	Hud_ChkRings	; if not, branch
0001CC92 4238 FE1F                  		clr.b	($FFFFFE1F).w
0001CC9C 2238 FE26                  		move.l	($FFFFFE26).w,d1 ; load	score
0001CCA0 6100 0000                  		bsr.w	Hud_Score
0001CCA4                            
0001CCA4                            Hud_ChkRings:
0001CCA4 4A38 FE1D                  		tst.b	($FFFFFE1D).w	; does the ring	counter	need updating?
0001CCA8 6700                       		beq.s	Hud_ChkTime	; if not, branch
0001CCAA 6A00                       		bpl.s	loc_1C6E4
0001CCAC 6100 0000                  		bsr.w	Hud_LoadZero
0001CCB0                            
0001CCB0                            loc_1C6E4:
0001CCB0 4238 FE1D                  		clr.b	($FFFFFE1D).w
0001CCBA 7200                       		moveq	#0,d1
0001CCBC 3238 FE20                  		move.w	($FFFFFE20).w,d1 ; load	number of rings
0001CCC0 6100 0000                  		bsr.w	Hud_Rings
0001CCC4                            
0001CCC4                            Hud_ChkTime:
0001CCC4 4A38 FE1E                  		tst.b	($FFFFFE1E).w	; is time counter locked?
0001CCC8 6700                       		beq.s	Hud_ChkLives	; if yes, branch
0001CCCA 4A78 F63A                  		tst.w	($FFFFF63A).w	; is the game paused?
0001CCCE 6600                       		bne.s	Hud_ChkLives	; if yes, branch
0001CCD0 43F8 FE22                  		lea	($FFFFFE22).w,a1; load time
0001CCD4 0C99 0009 3B3B             		cmpi.l	#$93B3B,(a1)+	; is the time 9.59?
0001CCDA 6700                       		beq.s	TimeOver	; if yes, branch
0001CCDC 5221                       		addq.b	#1,-(a1)	; add 1 to frame counter
0001CCDE 0C11 003C                  		cmpi.b	#60,(a1)	; have 60 frames (1 second) passed?
0001CCE2 6500                       		bcs.s	Hud_ChkLives	; if not, branch
0001CCE4 12BC 0000                  		move.b	#0,(a1)		; clear frame counter
0001CCE8 5221                       		addq.b	#1,-(a1)	; add 1 to seconds counter
0001CCEA 0C11 003C                  		cmpi.b	#60,(a1)	; have 60 seconds (1 minute) passed?
0001CCEE 6500                       		bcs.s	@RedrawCounter	; if not, branch
0001CCF0 12BC 0000                  		move.b	#0,(a1)		; clear seconds counter
0001CCF4 5221                       		addq.b	#1,-(a1)	; add 1 to minutes
0001CCF6 0C11 0009                  		cmpi.b	#9,(a1)		; have 9 minutes passed?
0001CCFA 6500                       		bcs.s	@RedrawCounter	; if not, branch
0001CCFC 12BC 0009                  		move.b	#9,(a1)		; set counter to 9 minutes
0001CD00                            
0001CD00                            ;loc_1C734:
