00003204 303B 0000                  		move.w	LSelectPointers(pc,d0.w),d0 ; load level number
00003208 6B00 FF7E                  		bmi.w	LevelSelect
0000320C 0C40 0700                  		cmpi.w	#$700,d0	; check	if level is 0700 (Special Stage)
00003210 6600                       		bne.s	LevSel_Level	; if not, branch
00003212 11FC 0010 F600             		move.b	#$10,($FFFFF600).w ; set screen	mode to	$10 (Special Stage)
00003218 4278 FE10                  		clr.w	($FFFFFE10).w	; clear	level
0000321C 11FC 0003 FE12             		move.b	#3,($FFFFFE12).w ; set lives to	3
00003222 7000                       		moveq	#0,d0
00003224 31C0 FE20                  		move.w	d0,($FFFFFE20).w ; clear rings
00003228 21C0 FE22                  		move.l	d0,($FFFFFE22).w ; clear time
0000322C 21C0 FE26                  		move.l	d0,($FFFFFE26).w ; clear score
00003230 4E75                       		rts	
00003232                            ; ===========================================================================
00003232                            
00003232                            LevSel_Level:				; XREF: LevSel_Level_SS
00003232 0240 3FFF                  		andi.w	#$3FFF,d0
