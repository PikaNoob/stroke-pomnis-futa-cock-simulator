00001558 34D9                       		move.w	(a1)+,(a2)+
0000155A 51C8 FFFA                  		dbf	d0,@WriteCues	; repeat for the number of items
0000155E                            
0000155E                            LoadPLC_Rts:
0000155E 4CDF 0600                  		movem.l	(sp)+,a1-a2	; load saved registers from the stack
00001562 4E75                       		rts	
00001564                            ; End of function LoadPLC
