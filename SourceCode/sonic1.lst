00003188                            
00003188                            LevelSelect:
00003188 11FC 0004 F62A             		move.b	#4,($FFFFF62A).w
0000318E 6100 F714                  		bsr.w	DelayProgram
00003192 6100 0000                  		bsr.w	LevSelControls
00003196 6100 E320                  		bsr.w	RunPLC_RAM
0000319A 4AB8 F680                  		tst.l	($FFFFF680).w	; is PLC queue empty?
0000319E 66E8                       		bne.s	LevelSelect	; if not, branch
000031A0 0238 00F0 F605                             andi.b	#A+B+C+Start,(Joypad|Press)	; is A, B, C or Start pressed?
000031A6 67E0                       		beq.s	LevelSelect			; if not, branch
000031A8 3038 FF82                  		move.w	($FFFFFF82).w,d0
000031AC 0C40 0014                  		cmpi.w	#$14,d0		; have you selected item $14 (sound test)?
000031B0 6600                       		bne.s	LevSel_Level_SS	; if not, go to	Level/SS subroutine
000031B2 3038 FF84                  		move.w	($FFFFFF84).w,d0
000031B6 0640 0080                  		addi.w	#$80,d0
000031BA 4A38 FFE3                  		tst.b	($FFFFFFE3).w	; is Japanese Credits cheat on?
000031BE 6700                       		beq.s	LevSel_NoCheat	; if not, branch
000031C0 0C40 009F                  		cmpi.w	#$9F,d0		; is sound $9F being played?
000031C4 6700                       		beq.s	LevSel_Ending	; if yes, branch
000031C6 0C40 009E                  		cmpi.w	#$9E,d0		; is sound $9E being played?
000031CA 6700                       		beq.s	LevSel_Credits	; if yes, branch
000031CC                            
000031CC                            LevSel_NoCheat:
000031CC 0C40 009F                  		cmpi.w	#$9F,d0		; is sound $81-$9F being played?
000031D0 6300                       		bls.s	LevSel_PlaySnd	; if yes, branch
000031D2 0C40 00A0                  		cmpi.w	#$A0,d0		; is sound $95-$A0 being played?
000031D6 65B0                       		bcs.s	LevelSelect	; if yes, branch
000031D8                            
000031D8                            LevSel_PlaySnd:
000031D8 6100 E004                  		bsr.w	PlaySound_Special
000031DC 60AA                       		bra.s	LevelSelect
