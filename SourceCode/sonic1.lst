00003398                            
00003398                            loc_33B6:				; XREF: loc_33E4
00003398 11FC 0004 F62A             		move.b	#4,($FFFFF62A).w
0000339E 6100 F5EA                  		bsr.w	DelayProgram
000033A2 6100 0000                  		bsr.w	DeformBgLayer
000033A6 6100 E550                  		bsr.w	PalCycle_Load
000033AA 6100 E1F2                  		bsr.w	RunPLC_RAM
000033AE 3038 D008                  		move.w	($FFFFD008).w,d0
000033B2 5440                       		addq.w	#2,d0
000033B4 31C0 D008                  		move.w	d0,($FFFFD008).w
000033B8 0C40 1C00                  		cmpi.w	#$1C00,d0
000033BC 6500                       		bcs.s	loc_33E4
000033BE 11FC 0000 F600             		move.b	#0,($FFFFF600).w ; set screen mode to 00 (level)
000033C4 4E75                       		rts	
000033C6                            ; ===========================================================================
000033C6                            
000033C6                            loc_33E4:				; XREF: Demo
000033C6 0238 0080 F605             		andi.b	#Start,(Joypad|Press)	; is Start button pressed?
000033CC 6600 FE56                  		bne.w	Title_ChkLevSel		; if yes, branch
000033D0 4A78 F614                  		tst.w	($FFFFF614).w
000033D4 6600 FFC2                  		bne.w	loc_33B6
000033D8 103C 00E0                  		move.b	#$E0,d0
000033DC 6100 DEE6                  		bsr.w	PlaySound_Special	; fade out music
000033E0 3038 FFF2                  		move.w	($FFFFFFF2).w,d0	; load demo number
000033E4 0240 0007                  		andi.w	#7,d0
000033E8 D040                       		add.w	d0,d0
000033EA 303B 0000                  		move.w	Demo_Levels(pc,d0.w),d0	; load level number for	demo
000033EE 31C0 FE10                  		move.w	d0,($FFFFFE10).w
000033F2 5278 FFF2                  		addq.w	#1,($FFFFFFF2).w ; add 1 to demo number
000033F6 0C78 0004 FFF2             		cmpi.w	#4,($FFFFFFF2).w ; is demo number less than 4?
000033FC 6500                       		bcs.s	loc_3422	; if yes, branch
000033FE 31FC 0000 FFF2             		move.w	#0,($FFFFFFF2).w ; reset demo number to	0
00003404                            
00003404                            loc_3422:
00003404 31FC 0001 FFF0             		move.w	#1,($FFFFFFF0).w ; turn	demo mode on
0000340A 11FC 0008 F600             		move.b	#8,($FFFFF600).w ; set screen mode to 08 (demo)
00003410 0C40 0600                  		cmpi.w	#$600,d0	 ; is level number 0600 (special stage)?
00003414 6600                       		bne.s	Demo_Level	 ; if not, branch
00003416 11FC 0010 F600             		move.b	#$10,($FFFFF600).w ; set screen	mode to	$10 (Special Stage)
0000341C 4278 FE10                  		clr.w	($FFFFFE10).w	; clear	level number
00003420 4238 FE16                  		clr.b	($FFFFFE16).w	; clear	special	stage number
00003424                            
