000011E4                            PauseGame:				; XREF: Level_MainLoop; et al
000011E4 4E71                       		nop	
000011E6 4A38 FE12                  		tst.b	($FFFFFE12).w	; do you have any lives	left?
000011EA 6700                       		beq.s	Unpause		; if not, branch
000011EC 4A78 F63A                  		tst.w	($FFFFF63A).w	; is game already paused?
000011F0 6600                       		bne.s	loc_13BE	; if yes, branch
000011F2                            
000011F2 0838 0007 F605             		btst	#iStart,(Joypad|Press)	; is Start button pressed?
000011F8 6700                       		beq.s	Pause_DoNothing		; if not, branch
