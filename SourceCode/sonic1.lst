0001CD16                            AddPoints:
0001CD16 11FC 0001 FE1F             		move.b	#1,($FFFFFE1F).w ; set score counter to	update
0001CD1C 45F8 FFC0                  		lea	($FFFFFFC0).w,a2
0001CD20 47F8 FE26                  		lea	($FFFFFE26).w,a3
0001CD24 D193                       		add.l	d0,(a3)		; add d0*10 to the score
0001CD26 223C 000F 423F             		move.l	#999999,d1
0001CD2C B293                       		cmp.l	(a3),d1		; is #999999 higher than the score?
0001CD2E 6200 0000                  		bhi.w	loc_1C6AC	; if yes, branch
0001CD32 2681                       		move.l	d1,(a3)		; reset	score to #999999
0001CD34 2481                       		move.l	d1,(a2)
