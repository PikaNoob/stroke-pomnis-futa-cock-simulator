0000D50E                            ; Subroutine to	make an	object fall downwards, increasingly fast
0000D50E                            ; ---------------------------------------------------------------------------
0000D50E                            
0000D50E                            ; ||||||||||||||| S U B	R O U T	I N E |||||||||||||||||||||||||||||||||||||||
