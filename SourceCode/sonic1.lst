00013950 303C 00D4                  		move.w	#$D4,d0
00013954 4EB9 0000 12C4             		jsr		(PlaySound_Special).l
0001395A                            	;	sfx 	sfx_PeeloutRelease
0001395A 6000 0000                  		bra.w	SCDPeelout_ResetScr
