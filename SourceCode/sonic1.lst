00075798                            ; ==============================================================================
00075798                            ; ------------------------------------------------------------------------------
00075798                            ; Mega PCM 2.0 - DAC Sound Driver
00075798                            ;
00075798                            ; Documentation, examples and source code are available at:
00075798                            ; - https://github.com/vladikcomper/MegaPCM/tree/2.x
00075798                            ;
00075798                            ; (c) 2012-2024, Vladikcomper
00075798                            ; ------------------------------------------------------------------------------
00075798                            
00075798                            ; ==============================================================================
00075798                            ; ------------------------------------------------------------------------------
00075798                            ; Constants
00075798                            ; ------------------------------------------------------------------------------
00075798                            
00075798                            
00075798                            ; ------------------------------------------------------------------------------
00075798                            ; Definitions for sample table
00075798                            ; ------------------------------------------------------------------------------
00075798                            
00075798 =00000001                  FLAGS_SFX:		equ	$01		; sample is SFX, normal drums cannot interrupt it
00075798 =00000002                  FLAGS_LOOP:		equ	$02		; loop sample indefinitely
00075798                            
00075798 =00000000                  TYPE_NONE:		equ	$00
00075798 =00000050                  TYPE_PCM:		equ	'P'
00075798 =00000054                  TYPE_PCM_TURBO:	equ	'T'
00075798 =00000044                  TYPE_DPCM:		equ	'D'
00075798                            
00075798                            ; ------------------------------------------------------------------------------
00075798                            ; Maximum playback rates:
00075798 =00007D00                  TYPE_PCM_TURBO_MAX_RATE:	equ	32000 ; Hz
00075798 =0000620C                  TYPE_PCM_MAX_RATE:			equ	25100 ; Hz
00075798 =00005078                  TYPE_DPCM_MAX_RATE:			equ	20600 ; Hz
00075798                            
00075798                            ; Internal driver's base rates for pitched playback.
00075798                            ; NOTICE: Actual max rates are slightly lower,
00075798                            ; because the highest pitch is 255/256, not 256/256.
00075798 =00006278                  TYPE_PCM_BASE_RATE:			equ	25208 ; Hz
00075798 =000050D3                  TYPE_DPCM_BASE_RATE:		equ	20691 ; Hz
00075798                            
00075798                            
00075798                            ; ------------------------------------------------------------------------------
00075798                            ; Return error codes for `MegaPCM_LoadSampleTable`
00075798                            ; ------------------------------------------------------------------------------
00075798                            
00075798 =00000001                  MPCM_ST_TOO_MANY_SAMPLES:			equ	$01
00075798 =00000002                  MPCM_ST_UNKNOWN_SAMPLE_TYPE:		equ	$02
00075798                            
00075798 =00000010                  MPCM_ST_PITCH_NOT_SET:				equ	$10
00075798                            
00075798 =00000020                  MPCM_ST_WAVE_INVALID_HEADER:		equ	$20
00075798 =00000021                  MPCM_ST_WAVE_BAD_AUDIO_FORMAT:		equ	$21
00075798 =00000022                  MPCM_ST_WAVE_NOT_MONO:				equ	$22
00075798 =00000023                  MPCM_ST_WAVE_NOT_8BIT:				equ	$23
00075798 =00000024                  MPCM_ST_WAVE_BAD_SAMPLE_RATE:		equ	$24
00075798 =00000025                  MPCM_ST_WAVE_MISSING_DATA_CHUNK:	equ	$25
00075798                            
00075798                            
00075798                            ; ------------------------------------------------------------------------------
00075798                            ; System Ports used by Mega PCM
00075798                            ; ------------------------------------------------------------------------------
00075798                            
00075798 =00A00000                  MPCM_Z80_RAM:		equ		$A00000
00075798 =00A11100                  MPCM_Z80_BUSREQ:	equ		$A11100
00075798 =00A11200                  MPCM_Z80_RESET:		equ		$A11200
00075798                            
00075798 =00A04000                  MPCM_YM2612_A0:		equ		$A04000
00075798 =00A04001                  MPCM_YM2612_D0:		equ		$A04001
00075798 =00A04002                  MPCM_YM2612_A1:		equ		$A04002
00075798 =00A04003                  MPCM_YM2612_D1:		equ		$A04003
00075798                            
00075798                            ; ------------------------------------------------------------------------------
00075798                            ; Z80 equates
00075798                            ; ------------------------------------------------------------------------------
00075798                            
00075798 =00001FC3                  Z_MPCM_DriverReady:	equ $1fc3
00075798 =00001FC2                  Z_MPCM_CommandInput:	equ $1fc2
00075798 =00001FC4                  Z_MPCM_VolumeInput:	equ $1fc4
00075798 =00001FC5                  Z_MPCM_SFXVolumeInput:	equ $1fc5
00075798 =00001FC6                  Z_MPCM_PanInput:	equ $1fc6
00075798 =00001FC7                  Z_MPCM_SFXPanInput:	equ $1fc7
00075798 =00001FDD                  Z_MPCM_LoopId:	equ $1fdd
00075798 =00001FDC                  Z_MPCM_ActiveSamplePitch:	equ $1fdc
00075798 =00001FE2                  Z_MPCM_VBlankActive:	equ $1fe2
00075798 =00001FE3                  Z_MPCM_CalibrationApplied:	equ $1fe3
00075798 =00001FE4                  Z_MPCM_CalibrationScore_ROM:	equ $1fe4
00075798 =00001FE6                  Z_MPCM_CalibrationScore_RAM:	equ $1fe6
00075798 =00001FE8                  Z_MPCM_LastErrorCode:	equ $1fe8
00075798 =00001976                  Z_MPCM_SampleTable:	equ $1976
00075798 =00000001                  Z_MPCM_COMMAND_STOP:	equ $1
00075798 =00000002                  Z_MPCM_COMMAND_PAUSE:	equ $2
00075798 =00000001                  Z_MPCM_LOOP_IDLE:	equ $1
00075798 =00000002                  Z_MPCM_LOOP_PAUSE:	equ $2
00075798 =00000010                  Z_MPCM_LOOP_PCM:	equ $10
00075798 =00000018                  Z_MPCM_LOOP_PCM_TURBO:	equ $18
00075798 =00000020                  Z_MPCM_LOOP_DPCM:	equ $20
00075798 =00000080                  Z_MPCM_LOOP_CALIBRATION:	equ $80
00075798 =00000002                  Z_MPCM_ERROR__BAD_INTERRUPT:	equ $2
00075798 =00000001                  Z_MPCM_ERROR__BAD_SAMPLE_TYPE:	equ $1
00075798 =00000080                  Z_MPCM_ERROR__UNKNOWN_COMMAND:	equ $80
00075798                            
00075798                            ; ==============================================================================
00075798                            ; ------------------------------------------------------------------------------
00075798                            ; Macros
00075798                            ; ------------------------------------------------------------------------------
00075798                            
00075798                            ; ------------------------------------------------------------------------------
00075798                            ; Macro to generate sample record in a sample table
00075798                            ; ------------------------------------------------------------------------------
00075798                            ; ARGUMENTS:
00075798                            ;	type - Sample type (TYPE_PCM, TYPE_DPCM, TYPE_PCM_TURBO or TYPE_NONE)
00075798                            ;	samplePtr - Sample pointer/name (assigned via `incdac` macro)
00075798                            ;	sampleRateHz? - (Optional) Playback rate in Hz, auto-detected for .WAV
00075798                            ;	flags? - (Optional) Additional flags (e.g. FLAGS_SFX or FLAGS_LOOP)
00075798                            ; ------------------------------------------------------------------------------
00075798                            
00075798                            dcSample: macro	type, samplePtr, sampleRateHz, flags
00075798                            	if narg>4
00075798                            		inform 2, "Too many arguments. USAGE: dcSample type, samplePtr, sampleRateHz, flags"
00075798                            	endif
00075798                            	dc.b	\type					; $00	- type
00075798                            	if \type=TYPE_PCM
00075798                            		if \sampleRateHz+0>TYPE_PCM_MAX_RATE
00075798                            			inform 2, "Invalid sample rate: \sampleRateHz\. TYPE_PCM only supports sample rates <= \#TYPE_PCM_MAX_RATE Hz"
00075798                            		endif
00075798                            		dc.b	\flags+0								; $01	- flags (optional)
00075798                            		dc.b	(\sampleRateHz+0)*256/TYPE_PCM_BASE_RATE; $02	- pitch (optional for .WAV files)
00075798                            		dc.b	0										; $03	- <RESERVED>
00075798                            		dc.l	\samplePtr								; $04	- start offset
00075798                            		dc.l	\samplePtr\_End							; $08	- end offset
00075798                            	elseif \type=TYPE_PCM_TURBO
00075798                            		if (\sampleRateHz+0<>TYPE_PCM_TURBO_MAX_RATE)&(\sampleRateHz+0<>0)
00075798                            			inform 2, "Invalid sample rate: \sampleRateHz\. TYPE_PCM_TURBO only supports sample rate of \#TYPE_PCM_TURBO_MAX_RATE Hz"
00075798                            		endif
00075798                            		dc.b	\flags+0								; $01	- flags (optional)
00075798                            		dc.b	$FF										; $02	- pitch (optional for .WAV files)
00075798                            		dc.b	0										; $03	- <RESERVED>
00075798                            		dc.l	\samplePtr								; $04	- start offset
00075798                            		dc.l	\samplePtr\_End							; $08	- end offset
00075798                            	elseif \type=TYPE_DPCM
00075798                            		if \sampleRateHz>TYPE_DPCM_MAX_RATE
00075798                            			inform 2, "Invalid sample rate: \sampleRateHz\. TYPE_DPCM only supports sample rates <= \#TYPE_DPCM_MAX_RATE Hz"
00075798                            		endif
00075798                            		dc.b	\flags+0								; $01	- flags (optional)
00075798                            		dc.b	(\sampleRateHz)*256/TYPE_DPCM_BASE_RATE	; $02	- pitch
00075798                            		dc.b	0										; $03	- <RESERVED>
00075798                            		dc.l	\samplePtr								; $04	- start offset
00075798                            		dc.l	\samplePtr\_End							; $08	- end offset
00075798                            	elseif \type=TYPE_NONE
00075798                            		dc.b	0, 0, 0
00075798                            		dc.l	0, 0
00075798                            	else
00075798                            		inform 2, "Unknown sample type. Please use one of: TYPE_PCM, TYPE_DPCM, TYPE_PCM_TURBO, TYPE_NONE"
00075798                            	endif
00075798                            	endm
00075798                            
00075798                            ; ------------------------------------------------------------------------------
00075798                            ; Macro to include a sample file
00075798                            ; ------------------------------------------------------------------------------
00075798                            ; ARGUMENTS:
00075798                            ;	name - Name assigned to the sample (label)
00075798                            ;	path - Sample's include path (string)
00075798                            ; ------------------------------------------------------------------------------
00075798                            
00075798                            incdac:	macro name, path
00075798                            		even
00075798                            	\name:
00075798                            		incbin	\path
00075798                            	\name\_End:
00075798                            	endm
00075798                            
00075798                            ; ------------------------------------------------------------------------------
00075798                            ; Macro to stop Z80 and take over its bus
00075798                            ; ------------------------------------------------------------------------------
00075798                            ; ARGUMENTS:
00075798                            ;	opBusReq? - (Optional) Custom operand for Z80_BUSREQ
00075798                            ; ------------------------------------------------------------------------------
00075798                            
00075798                            MPCM_stopZ80:	macro opBusReq
00075798                            	pusho
00075798                            	opt		l-		; make sure "@" marks local labels
00075798                            	if narg=1
00075798                            		move.w	#$100, \opBusReq
00075798                            		@wait\@:
00075798                            			btst	#0, \opBusReq
00075798                            			bne.s	@wait\@
00075798                            	else
00075798                            		move.w	#$100, MPCM_Z80_BUSREQ
00075798                            		@wait\@:
00075798                            			btst	#0, MPCM_Z80_BUSREQ
00075798                            			bne.s	@wait\@
00075798                            	endif
00075798                            	popo
00075798                            	endm
00075798                            
00075798                            ; ------------------------------------------------------------------------------
00075798                            ; Macro to start Z80 and release its bus
00075798                            ; ------------------------------------------------------------------------------
00075798                            ; ARGUMENTS:
00075798                            ;	opBusReq? - (Optional) Custom operand for Z80_BUSREQ
00075798                            ; ------------------------------------------------------------------------------
00075798                            
00075798                            MPCM_startZ80:	macro opBusReq
00075798                            	if narg=1
00075798                            		move.w	#0, \opBusReq
00075798                            	else
00075798                            		move.w	#0, MPCM_Z80_BUSREQ
00075798                            	endif
00075798                            	endm
00075798                            
00075798                            ; ------------------------------------------------------------------------------
00075798                            ; Ensures Mega PCM 2 isn't busy writing to YM (other than DAC output obviously)
00075798                            ; ------------------------------------------------------------------------------
00075798                            ; ARGUMENTS:
00075798                            ;	opBusReq? - (Optional) Custom operand for Z80_BUSREQ
00075798                            ; ------------------------------------------------------------------------------
00075798                            
00075798                            MPCM_ensureYMWriteReady:	macro opBusReq
00075798                            	pusho
00075798                            	opt		l-		; make sure "@" marks local labels
00075798                            	@chk_ready\@:
00075798                            		tst.b	(MPCM_Z80_RAM+Z_MPCM_DriverReady).l
00075798                            		bne.s	@ready\@
00075798                            		MPCM_startZ80 \opBusReq
00075798                            		move.w	d0, -(sp)
00075798                            		moveq	#10, d0
00075798                            		dbf		d0, *						; waste 100+ cycles
00075798                            		move.w	(sp)+, d0
00075798                            		MPCM_stopZ80 \opBusReq
00075798                            		bra.s	@chk_ready\@
00075798                            	@ready\@:
00075798                            	popo
00075798                            	endm
00075798                            
