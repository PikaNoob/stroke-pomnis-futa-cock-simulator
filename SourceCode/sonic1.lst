0000335C                            ; ---------------------------------------------------------------------------
0000335C                            ; Level	select - level pointers
0000335C                            ; ---------------------------------------------------------------------------
0000335C                            ; Vladikcomper: Pointers were converted from bin to asm format for
0000335C                            ;		more convenient editing.
0000335C                            LSelectPointers:
0000335C                            		include	"_inc\Level select pointers.asm"
0000335C                            ; ===========================================================================
0000335C                            ; *              S1HS - Levels order in Level Select Menu                   *
0000335C                            ; ===========================================================================
0000335C                            ; This file stores level order in level select menu
0000335C                            ; The format of each item is: ZZAA, where ZZ is zone and AA is act number.
0000335C                            ; ===========================================================================
0000335C                            
0000335C 0000                       		dc.w	$0000	; GHZ 1
0000335E 0001                       		dc.w	$0001	; GHZ 2
00003360 0002                       		dc.w	$0002	; GHZ 3
00003362                            
00003362 0100                       		dc.w	$0100	; LZ 1
00003364 0101                       		dc.w	$0101	; LZ 2
00003366 0102                       		dc.w	$0102	; LZ 3
00003368                            
00003368 0200                       		dc.w	$0200	; MZ 1
0000336A 0201                       		dc.w	$0201	; MZ 2
0000336C 0202                       		dc.w	$0202	; MZ 3
0000336E                            
0000336E 0300                       		dc.w	$0300	; SLZ 1
00003370 0301                       		dc.w	$0301	; SLZ 2
00003372 0302                       		dc.w	$0302	; SLZ 3
00003374                            
00003374 0400                       		dc.w	$0400	; SYZ 1
00003376 0401                       		dc.w	$0401	; SYZ 2
00003378 0402                       		dc.w	$0402	; SYZ 3
0000337A                            
0000337A 0500                       		dc.w	$0500	; SBZ 1
0000337C 0501                       		dc.w	$0501	; SBZ 2
0000337E 0103                       		dc.w	$0103	; SBZ 3 (actually LZ 4)
00003380                            
00003380 0502                       		dc.w	$0502	; Final Zone (actually SBZ 3)
00003382                            
00003382 0700                       		dc.w	$0700	; Special Stage
00003384 8000                       		dc.w	$8000	; Sound select
00003384 8000                       		dc.w	$8000	; Sound select
00003386                            		even
