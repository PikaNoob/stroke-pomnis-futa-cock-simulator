0000D618                            ; ---------------------------------------------------------------------------
0000D618                            ; Subroutine translating object	speed to update	object position
0000D618                            ; ---------------------------------------------------------------------------
0000D618                            
0000D618                            ; ||||||||||||||| S U B	R O U T	I N E |||||||||||||||||||||||||||||||||||||||
0000D618                            
0000D618                            SpeedToPos:
0000D618 3028 0010                  		move.w	$10(a0),d0	; load horizontal speed
0000D61C 48C0                       		ext.l	d0
0000D61E E188                       		lsl.l	#8,d0		; multiply speed by $100
0000D620 D1A8 0008                  		add.l	d0,8(a0)	; add to x-axis	position
0000D624 3028 0012                  		move.w	$12(a0),d0	; load vertical	speed
0000D628 48C0                       		ext.l	d0
0000D62A E188                       		lsl.l	#8,d0		; multiply by $100
0000D62C D1A8 000C                  		add.l	d0,$C(a0)	; add to y-axis	position
0000D630 4E75                       		rts	
