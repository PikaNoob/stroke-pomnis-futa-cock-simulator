00001D0A                            
00001D0A                            ; ||||||||||||||| S U B	R O U T	I N E |||||||||||||||||||||||||||||||||||||||
00001D0A                            
00001D0A                            
00001D0A                            Pal_AddColor:				; XREF: Pal_FadeIn
00001D0A 1A11                       		move.b	(a1),d5					; MJ: load blue
00001D0C 3219                       		move.w	(a1)+,d1				; MJ: load green and red
00001D0E 1401                       		move.b	d1,d2					; MJ: load red
00001D10 E809                       		lsr.b	#$04,d1					; MJ: get only green
00001D12 0202 000E                  		andi.b	#$0E,d2					; MJ: get only red
00001D16 3610                       		move.w	(a0),d3					; MJ: load current colour in buffer
00001D18 B805                       		cmp.b	d5,d4					; MJ: is it time for blue to fade?
00001D1A 6200 0000                  		bhi	FCI_NoBlue				; MJ: if not, branch
00001D1E 0643 0200                  		addi.w	#$0200,d3				; MJ: increase blue
00001D22                            
00001D22                            FCI_NoBlue:
00001D22 B801                       		cmp.b	d1,d4					; MJ: is it time for green to fade?
00001D24 6200 0000                  		bhi	FCI_NoGreen				; MJ: if not, branch
00001D28 0603 0020                  		addi.b	#$20,d3					; MJ: increase green
00001D2C                            
00001D2C                            FCI_NoGreen:
00001D2C B802                       		cmp.b	d2,d4					; MJ: is it time for red to fade?
00001D2E 6200 0000                  		bhi	FCI_NoRed				; MJ: if not, branch
00001D32 5403                       		addq.b	#$02,d3					; MJ: increase red
00001D34                            
00001D34                            FCI_NoRed:
00001D34 30C3                       		move.w	d3,(a0)+				; MJ: save colour
00001D36 4E75                       		rts						; MJ: return
00001D38                            
00001D38                            ; End of function Pal_AddColor
