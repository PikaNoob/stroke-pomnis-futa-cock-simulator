00001CCA 41F8 FB00                  		lea	($FFFFFB00).w,a0
00001CCE 43F8 FB80                  		lea	($FFFFFB80).w,a1
00001CD2 1038 F626                  		move.b	($FFFFF626).w,d0
00001CD6 D0C0                       		adda.w	d0,a0
00001CD8 D2C0                       		adda.w	d0,a1
00001CDA 1038 F627                  		move.b	($FFFFF627).w,d0
