0000C910 337C 8541 0002             		move.w	#$8541,2(a1)
0000C916 137C 0000 0001             		move.b	#0,1(a1)
0000C91C 43E9 0040                  		lea	$40(a1),a1	; next object
0000C920 51C9 FFC2                  		dbf	d1,Obj7F_Loop	; loop for d1 number of	emeralds
