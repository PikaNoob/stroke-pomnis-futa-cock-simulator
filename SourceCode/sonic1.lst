000013AE 22C2                       		move.l	d2,(a1)+ ; store command
000013B0                             
000013B0 21C9 C8FC                  		move.l	a1,($FFFFC8FC).w ; set the next free slot address
000013B4 B2FC C8FC                  		cmpa.w	#$C8FC,a1
000013B8 6700                       		beq.s	QueueDMATransfer_Done ; return if there's no more room in the buffer
000013BA 32BC 0000                  		move.w	#0,(a1) ; put a stop token at the end of the used part of the buffer
000013BE                            
000013BE                            QueueDMATransfer_Done:
000013BE 4E75                       		rts
000013C0                            ; End of function QueueDMATransfer
