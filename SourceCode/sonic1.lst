00003240 11FC 0003 FE12             		move.b	#3,($FFFFFE12).w ; set lives to	3
00003246 7000                       		moveq	#0,d0
00003248 31C0 FE20                  		move.w	d0,($FFFFFE20).w ; clear rings
0000324C 21C0 FE22                  		move.l	d0,($FFFFFE22).w ; clear time
00003250 21C0 FE26                  		move.l	d0,($FFFFFE26).w ; clear score
00003254 11C0 FE16                  		move.b	d0,($FFFFFE16).w ; clear special stage number
00003258 11C0 FE57                  		move.b	d0,($FFFFFE57).w ; clear emeralds
0000325C 21C0 FE58                  		move.l	d0,($FFFFFE58).w ; clear emeralds
00003260 21C0 FE5C                  		move.l	d0,($FFFFFE5C).w ; clear emeralds
00003264 11C0 FE18                  		move.b	d0,($FFFFFE18).w ; clear continues
00003268 103C 00E0                  		move.b	#$E0,d0
0000326C 6100 DF70                  		bsr.w	PlaySound_Special ; fade out music
00003270 4E75                       		rts	
