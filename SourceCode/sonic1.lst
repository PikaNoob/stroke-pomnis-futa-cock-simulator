00003386                            ; Level	select codes
00003386                            ; ---------------------------------------------------------------------------
00003386                            
00003386 0102 0408 00FF             LSCode_J:	dc.b	Up, Down, Left, Right, 0, $FF
0000338C 0102 0408 00FF             LSCode_US:	dc.b	Up, Down, Left, Right, 0, $FF
