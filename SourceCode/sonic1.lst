00001574 43F1 0000                  		lea	(a1,d0.w),a1	; load PLC block to a1
00001578 6100                       		bsr.s	ClearPLC
0000157A 45F8 F680                  		lea	($FFFFF680).w,a2 ; load PLC queue to a2
0000157E 3019                       		move.w	(a1)+,d0	; move number of items in block to d0
00001580 6B00                       		bmi.s	LoadPLC2_Rts	; if it's negative (>=$80), then something is wrong, exit
