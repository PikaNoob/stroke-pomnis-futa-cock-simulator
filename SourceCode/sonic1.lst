0000319C 6A00                       		bpl.s	@RegionJ	; if Japanese, branch
0000319E 41F9 0000 0000             		lea	(LSCode_US).l,a0 ; load US code
000031A4 6000                       		bra.s	Title_EnterCheat
000031A6                            @RegionJ:
000031A6 41F9 0000 0000             		lea	(LSCode_J).l,a0 ; load J code
000031AC                            
000031AC                            Title_EnterCheat:			; XREF: Title_ChkRegion
000031AC 3038 FFE4                  		move.w	($FFFFFFE4).w,d0
000031B0 D0C0                       		adda.w	d0,a0
000031B2 1038 F605                  		move.b	(Joypad|Press),d0 	; get button presses
000031B6 0200 000F                  		andi.b	#Up+Down+Left+Right,d0	; read only up/down/left/right buttons
000031BA B010                       		cmp.b	(a0),d0			; does button press match the cheat code?
000031BC 6600                       		bne.s	loc_3210		; if not, branch
000031BE 5278 FFE4                  		addq.w	#1,($FFFFFFE4).w	; next button press
000031C2 4A00                       		tst.b	d0
000031C4 6600                       		bne.s	Title_CountC
000031C6 41F8 FFE0                  		lea	($FFFFFFE0).w,a0
000031CA 3238 FFE6                  		move.w	($FFFFFFE6).w,d1
000031CE E249                       		lsr.w	#1,d1
000031D0 0241 0003                  		andi.w	#3,d1
000031D4 6700                       		beq.s	Title_PlayRing
000031D6 4A38 FFF8                  		tst.b	($FFFFFFF8).w
000031DA 6A00                       		bpl.s	Title_PlayRing
000031DC 7201                       		moveq	#1,d1
000031DE 1181 1001                  		move.b	d1,1(a0,d1.w)
000031E2                            
000031E2                            Title_PlayRing:
000031E2 11BC 0001 1000             		move.b	#1,(a0,d1.w)	; activate cheat
000031E8 103C 00B5                  		move.b	#$B5,d0		; play ring sound when code is entered
000031EC 6100 E0D6                  		bsr.w	PlaySound_Special
000031F0 6000                       		bra.s	Title_CountC
000031F2                            ; ===========================================================================
000031F2                            
000031F2                            loc_3210:				; XREF: Title_EnterCheat
000031F2 4A00                       		tst.b	d0
000031F4 6700                       		beq.s	Title_CountC
000031F6 0C78 0009 FFE4             		cmpi.w	#9,($FFFFFFE4).w
000031FC 6700                       		beq.s	Title_CountC
000031FE 31FC 0000 FFE4             		move.w	#0,($FFFFFFE4).w
00003204                            
00003204                            Title_CountC:
00003204 1038 F605 0200 0020        		tpress	C,(Joypad)		; is C button pressed?
0000320C 6700                       		beq.s	loc_3230		; if not, branch
0000320E 5278 FFE6                  		addq.w	#1,($FFFFFFE6).w	; increment C button counter
00003212                            
00003212                            loc_3230:
00003212 4A78 F614                  		tst.w	($FFFFF614).w
00003216 6700 0000                  		beq.w	Demo
0000321A 0238 0080 F605             		andi.b	#Start,(Joypad|Press)	; check if Start is pressed
00003220 6700 FF3C                  		beq.w	loc_317C		; if not, branch
00003224                            
00003224                            Title_ChkLevSel:
00003224 4A38 FFE0                  		tst.b	($FFFFFFE0).w		; check	if level select	code is	on
00003228 6700 0000                  		beq.w	PlayLevel		; if not, play level
0000322C 0838 0006 F604             		btst	#iA,(Joypad|Held).w	; check if A is held
00003232 6700 0000                  		beq.w	PlayLevel		; if not, play level
00003236 7002                       		moveq	#2,d0
00003238 6100 EEC0                  		bsr.w	PalLoad2		; load level select pallet
0000323C 43F8 CC00                  		lea	($FFFFCC00).w,a1
00003240 7000                       		moveq	#0,d0
00003242 323C 00DF                  		move.w	#$DF,d1
00003246                            
00003246                            Title_ClrScroll:
00003246 22C0                       		move.l	d0,(a1)+
00003248 51C9 FFFC                  		dbf	d1,Title_ClrScroll ; fill scroll data with 0
0000324C                            
0000324C 21C0 F616                  		move.l	d0,($FFFFF616).w
00003250 46FC 2700                  		move	#$2700,sr		; disable interrupts
00003254 4DF9 00C0 0000             		lea	($C00000).l,a6
00003264 323C 03FF                  		move.w	#$3FF,d1
00003268                            
00003268                            Title_ClrVram:
00003268 2C80                       		move.l	d0,(a6)
0000326A 51C9 FFFC                  		dbf	d1,Title_ClrVram ; fill	VRAM with 0
0000326E                            
0000326E 6100 0000                  		bsr.w	LevSelTextLoad
