0000D5D2 227B 00BE                  		movea.l	BldSpr_ScrPos(pc,d0.w),a1
0000D5D6 7000                       		moveq	#0,d0
0000D5D8 1028 0019                  		move.b	$19(a0),d0	; move H-radius to d0
0000D5DC 3628 0008                  		move.w	8(a0),d3	; move X-axis to d3
0000D5E0 9651                       		sub.w	(a1),d3
0000D5E2 3203                       		move.w	d3,d1
0000D5E4 D240                       		add.w	d0,d1
0000D5E6 6B00 0000                  		bmi.w	BS_NextObject	; if object is out of screen, branch
0000D5EA 3203                       		move.w	d3,d1
0000D5EC 9240                       		sub.w	d0,d1
0000D5EE 0C41 0140                  		cmpi.w	#$140,d1
0000D5F2 6C00                       		bge.s	BS_NextObject	; if object is out of screen, branch
0000D5F4 0643 0080                  		addi.w	#$80,d3
0000D5F8 0804 0004                  		btst	#4,d4
0000D5FC 6700                       		beq.s	loc_D6E8
0000D5FE 7000                       		moveq	#0,d0
0000D600 1028 0016                  		move.b	$16(a0),d0	; move V-radius to d0
0000D604 3428 000C                  		move.w	$C(a0),d2	; move Y-axis to d2
0000D608 9469 0004                  		sub.w	4(a1),d2
0000D60C 3202                       		move.w	d2,d1
0000D60E D240                       		add.w	d0,d1
0000D610 6B00                       		bmi.s	BS_NextObject	; if object is out of screen, branch
0000D612 3202                       		move.w	d2,d1
0000D614 9240                       		sub.w	d0,d1
0000D616 0C41 00E0                  		cmpi.w	#$E0,d1
0000D61A 6C00                       		bge.s	BS_NextObject	; if object is out of screen, branch
