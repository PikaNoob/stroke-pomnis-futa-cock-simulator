000034E4 6100 0000                  		bsr.w	LevSel_ChgLine
000034E8 0684 0080 0000             		addi.l	#$800000,d4
000034EE 51C9 FFF0                  		dbf	d1,loc_34FE
000034F2 7000                       		moveq	#0,d0
000034F4 3038 FF82                  		move.w	($FFFFFF82).w,d0
000034F8 3200                       		move.w	d0,d1
000034FA 283C 6210 0003             		move.l	#$62100003,d4
00003500 EF48                       		lsl.w	#7,d0
00003502 4840                       		swap	d0
00003504 D880                       		add.l	d0,d4
00003506 43F9 0000 0000             		lea	(LevelMenuText).l,a1
0000350C E749                       		lsl.w	#3,d1
