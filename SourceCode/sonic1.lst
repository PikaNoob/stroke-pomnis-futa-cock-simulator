00003272                            ; ---------------------------------------------------------------------------
00003272                            ; Level	Select
00003272                            ; ---------------------------------------------------------------------------
00003272                            
00003272                            LevelSelect:
00003272 11FC 0004 F62A             		move.b	#4,($FFFFF62A).w
00003278 6100 F710                  		bsr.w	DelayProgram
0000327C 6100 0000                  		bsr.w	LevSelControls
00003280 6100 E31C                  		bsr.w	RunPLC_RAM
00003284 4AB8 F680                  		tst.l	($FFFFF680).w	; is PLC queue empty?
00003288 66E8                       		bne.s	LevelSelect	; if not, branch
0000328A 0238 00F0 F605                             andi.b	#A+B+C+Start,(Joypad|Press)	; is A, B, C or Start pressed?
00003290 67E0                       		beq.s	LevelSelect			; if not, branch
00003292 3038 FF82                  		move.w	($FFFFFF82).w,d0
00003296 0C40 0014                  		cmpi.w	#$14,d0		; have you selected item $14 (sound test)?
0000329A 6600                       		bne.s	LevSel_Level_SS	; if not, go to	Level/SS subroutine
0000329C 3038 FF84                  		move.w	($FFFFFF84).w,d0
000032A0 0640 0080                  		addi.w	#$80,d0
000032A4 4A38 FFE3                  		tst.b	($FFFFFFE3).w	; is Japanese Credits cheat on?
000032A8 6700                       		beq.s	LevSel_NoCheat	; if not, branch
000032AA 0C40 009F                  		cmpi.w	#$9F,d0		; is sound $9F being played?
000032AE 6700                       		beq.s	LevSel_Ending	; if yes, branch
000032B0 0C40 009E                  		cmpi.w	#$9E,d0		; is sound $9E being played?
000032B4 6700                       		beq.s	LevSel_Credits	; if yes, branch
000032B6                            
000032B6                            LevSel_NoCheat:
000032B6 0C40 009F                  		cmpi.w	#$9F,d0		; is sound $81-$9F being played?
000032BA 6300                       		bls.s	LevSel_PlaySnd	; if yes, branch
000032BC 0C40 00A0                  		cmpi.w	#$A0,d0		; is sound $95-$A0 being played?
000032C0 65B0                       		bcs.s	LevelSelect	; if yes, branch
000032C2                            
000032C2                            LevSel_PlaySnd:
000032C2 6100 E000                  		bsr.w	PlaySound_Special
000032C6 60AA                       		bra.s	LevelSelect
000032C8                            ; ===========================================================================
000032C8                            
000032C8                            LevSel_Ending:				; XREF: LevelSelect
000032C8 11FC 0018 F600             		move.b	#$18,($FFFFF600).w ; set screen	mode to	$18 (Ending)
000032CE 31FC 0600 FE10             		move.w	#$600,($FFFFFE10).w ; set level	to 0600	(Ending)
000032D4 4E75                       		rts	
000032D6                            ; ===========================================================================
000032D6                            
000032D6                            LevSel_Credits:				; XREF: LevelSelect
000032D6 11FC 001C F600             		move.b	#$1C,($FFFFF600).w ; set screen	mode to	$1C (Credits)
000032DC 103C 009D                  		move.b	#$9D,d0
000032E0 6100 DFE2                  		bsr.w	PlaySound_Special ; play credits music
000032E4 31FC 0000 FFF4             		move.w	#0,($FFFFFFF4).w
000032EA 4E75                       		rts	
000032EC                            ; ===========================================================================
000032EC                            
000032EC                            LevSel_Level_SS:			; XREF: LevelSelect
000032EC D040                       		add.w	d0,d0
000032EE 303B 0000                  		move.w	LSelectPointers(pc,d0.w),d0 ; load level number
000032F2 6B00 FF7E                  		bmi.w	LevelSelect
000032F6 0C40 0700                  		cmpi.w	#$700,d0	; check	if level is 0700 (Special Stage)
000032FA 6600                       		bne.s	LevSel_Level	; if not, branch
000032FC 11FC 0010 F600             		move.b	#$10,($FFFFF600).w ; set screen	mode to	$10 (Special Stage)
00003302 4278 FE10                  		clr.w	($FFFFFE10).w	; clear	level
00003306 11FC 0003 FE12             		move.b	#3,($FFFFFE12).w ; set lives to	3
0000330C 7000                       		moveq	#0,d0
0000330E 31C0 FE20                  		move.w	d0,($FFFFFE20).w ; clear rings
00003312 21C0 FE22                  		move.l	d0,($FFFFFE22).w ; clear time
00003316 21C0 FE26                  		move.l	d0,($FFFFFE26).w ; clear score
0000331A 4E75                       		rts	
0000331C                            ; ===========================================================================
0000331C                            
0000331C                            LevSel_Level:				; XREF: LevSel_Level_SS
0000331C 0240 3FFF                  		andi.w	#$3FFF,d0
00003320 31C0 FE10                  		move.w	d0,($FFFFFE10).w ; set level number
00003324                            
00003324                            PlayLevel:
00003324 11FC 000C F600             		move.b	#$C,($FFFFF600).w ; set	screen mode to $0C (level)
0000332A 11FC 0003 FE12             		move.b	#3,($FFFFFE12).w ; set lives to	3
00003330 7000                       		moveq	#0,d0
00003332 31C0 FE20                  		move.w	d0,($FFFFFE20).w ; clear rings
00003336 21C0 FE22                  		move.l	d0,($FFFFFE22).w ; clear time
0000333A 21C0 FE26                  		move.l	d0,($FFFFFE26).w ; clear score
0000333E 11C0 FE16                  		move.b	d0,($FFFFFE16).w ; clear special stage number
00003342 11C0 FE57                  		move.b	d0,($FFFFFE57).w ; clear emeralds
00003346 21C0 FE58                  		move.l	d0,($FFFFFE58).w ; clear emeralds
0000334A 21C0 FE5C                  		move.l	d0,($FFFFFE5C).w ; clear emeralds
0000334E 11C0 FE18                  		move.b	d0,($FFFFFE18).w ; clear continues
00003352 103C 00E0                  		move.b	#$E0,d0
00003356 6100 DF6C                  		bsr.w	PlaySound_Special ; fade out music
0000335A 4E75                       		rts	
