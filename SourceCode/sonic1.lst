0000D26A 234B 0004                  		move.l	a3,4(a1)
0000D26E 1345 0001                  		move.b	d5,1(a1)
0000D272 3368 0008 0008             		move.w	8(a0),8(a1)
0000D278 3368 000C 000C             		move.w	$C(a0),$C(a1)
0000D27E 3368 0002 0002             		move.w	2(a0),2(a1)
0000D284 1368 0018 0018             		move.b	$18(a0),$18(a1)
0000D28A 1368 0019 0019             		move.b	$19(a0),$19(a1)
0000D290 335C 0010                  		move.w	(a4)+,$10(a1)
0000D294 335C 0012                  		move.w	(a4)+,$12(a1)
0000D298 B3C8                       		cmpa.l	a0,a1
0000D29A 6400                       		bcc.s	loc_D268
0000D29C 2F08                       		move.l	a0,-(sp)
0000D29E 2049                       		movea.l	a1,a0
0000D2A0 6100 0000                  		bsr.w	SpeedToPos
0000D2A4 D568 0012                  		add.w	d2,$12(a0)
0000D2A8 205F                       		movea.l	(sp)+,a0
0000D2AA 6100 0000                  		bsr.w	DisplaySprite2
