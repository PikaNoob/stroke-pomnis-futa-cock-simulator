00013F72 1228 0008                  		move.b	8(a0),d1
00013F76 0241 007F                  		andi.w	#$7F,d1
00013F7A D041                       		add.w	d1,d0
00013F7C 43F8 A400                  		lea	($FFFFA400).w,a1
00013F80 1231 0000                  		move.b	(a1,d0.w),d1	; d1 is	the 256x256 tile Sonic is currently on
00013F84 B238 F7AE                  		cmp.b	($FFFFF7AE).w,d1
00013F88 6700 F7F2                  		beq.w	Obj01_ChkRoll
00013F8C B238 F7AF                  		cmp.b	($FFFFF7AF).w,d1
00013F90 6700 F7EA                  		beq.w	Obj01_ChkRoll
00013F94 B238 F7AC                  		cmp.b	($FFFFF7AC).w,d1
00013F98 6700                       		beq.s	loc_13976
00013F9A B238 F7AD                  		cmp.b	($FFFFF7AD).w,d1
00013F9E 6700                       		beq.s	loc_13966
00013FA0 08A8 0006 0001             		bclr	#6,1(a0)
00013FA6 4E75                       		rts	
00013FA8                            ; ===========================================================================
00013FA8                            
00013FA8                            loc_13966:
00013FA8 0828 0001 0022             		btst	#1,$22(a0)
00013FAE 6700                       		beq.s	loc_13976
00013FB0 08A8 0006 0001             		bclr	#6,1(a0)	; send Sonic to	high plane
00013FB6 4E75                       		rts	
00013FB8                            ; ===========================================================================
00013FB8                            
00013FB8                            loc_13976:
00013FB8 3428 0008                  		move.w	8(a0),d2
00013FBC 0C02 002C                  		cmpi.b	#$2C,d2
00013FC0 6400                       		bcc.s	loc_13988
00013FC2 08A8 0006 0001             		bclr	#6,1(a0)	; send Sonic to	high plane
00013FC8 4E75                       		rts	
00013FCA                            ; ===========================================================================
00013FCA                            
00013FCA                            loc_13988:
00013FCA 0C02 00E0                  		cmpi.b	#-$20,d2
00013FCE 6500                       		bcs.s	loc_13996
00013FD0 08E8 0006 0001             		bset	#6,1(a0)	; send Sonic to	low plane
00013FD6 4E75                       		rts	
00013FD8                            ; ===========================================================================
00013FD8                            
00013FD8                            loc_13996:
00013FD8 0828 0006 0001             		btst	#6,1(a0)
00013FDE 6600                       		bne.s	loc_139B2
00013FE0 1228 0026                  		move.b	$26(a0),d1
00013FE4 6700                       		beq.s	locret_139C2
00013FE6 0C01 0080                  		cmpi.b	#-$80,d1
00013FEA 6200                       		bhi.s	locret_139C2
00013FEC 08E8 0006 0001             		bset	#6,1(a0)	; send Sonic to	low plane
00013FF2 4E75                       		rts	
00013FF4                            ; ===========================================================================
00013FF4                            
00013FF4                            loc_139B2:
00013FF4 1228 0026                  		move.b	$26(a0),d1
00013FF8 0C01 0080                  		cmpi.b	#-$80,d1
00013FFC 6300                       		bls.s	locret_139C2
00013FFE 08A8 0006 0001             		bclr	#6,1(a0)	; send Sonic to	high plane
