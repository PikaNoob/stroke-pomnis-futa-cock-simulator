0000D294                            ObjectsLoad:				; XREF: TitleScreen; et al
0000D294 41F8 D000                  		lea	($FFFFD000).w,a0 ; load object RAM
0000D298 7E7F                       		moveq	#$7F,d7
0000D29A 7000                       		moveq	#0,d0
0000D29C 0C38 0006 D024             		cmpi.b	#6,($FFFFD024).w ; is Sonic Dying (primary routine >= 6)?
0000D2A2 6400                       		bcc.s	ObjectsFreeze	; if yes, branch
0000D2A4                            
0000D2A4                            ExecuteObjects:
0000D2A4 1010                       		move.b	(a0),d0		; load object's id
0000D2A6 6700                       		beq.s	@NextObject	; if it's zero, skip
0000D2A8 D040                       		add.w	d0,d0
0000D2AA D040                       		add.w	d0,d0
0000D2AC 227B 0000                  		movea.l	Obj_Index-4(pc,d0.w),a1
0000D2B0 4E91                       		jsr	(a1)		; run the object's code
0000D2B2 7000                       		moveq	#0,d0
0000D2B4                            
0000D2B4                            @NextObject:
0000D2B4 41E8 0040                  		lea	$40(a0),a0	; next object
0000D2B8 51CF FFEA                  		dbf	d7,ExecuteObjects
0000D2BC 4E75                       		rts
0000D2BE                            
0000D2BE                            ; ===========================================================================
0000D2BE                            ; ---------------------------------------------------------------------------
0000D2BE                            ; Just displays objects without running their code
0000D2BE                            ; Runs if Sonic is in dying state
0000D2BE                            ; ---------------------------------------------------------------------------
0000D2BE                            
0000D2BE                            ;loc_D362:
0000D2BE                            ObjectsFreeze:
0000D2BE 7E1F                       		moveq	#$1F,d7
0000D2C0 61E2                       		bsr.s	ExecuteObjects	; run code only for reserved object SST
0000D2C2 7E5F                       		moveq	#$5F,d7
0000D2C4                            
0000D2C4                            DisplayObjects:
0000D2C4 7000                       		moveq	#0,d0
0000D2C6 1010                       		move.b	(a0),d0		; load object's id
0000D2C8 6700                       		beq.s	@NextObject	; if it's zero, branch
0000D2CA 4A28 0001                  		tst.b	1(a0)		; test render flag
0000D2CE 6A00                       		bpl.s	@NextObject	; if bit #7 isn't set, branch
0000D2D0 6100 0000                  		bsr.w	DisplaySprite
0000D2D4                            
0000D2D4                            @NextObject:
0000D2D4 41E8 0040                  		lea	$40(a0),a0	; next object
0000D2D8 51CF FFEA                  		dbf	d7,DisplayObjects
0000D2DC 4E75                       		rts
0000D2DE                            ; End of function ObjectsLoad
