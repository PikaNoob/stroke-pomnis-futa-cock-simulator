000138A4                            ; ---------------------------------------------------------------------------
000138A4                            ; Subroutine to make Sonic perform a peelout
000138A4                            ; ---------------------------------------------------------------------------
000138A4                             
000138A4                            ; ||||||||||||||| S U B	R O U T	I N E |||||||||||||||||||||||||||||||||||||||
000138A4                            
000138A4                            Sonic_Peelout:
000138A4                            	include "_new\peelout.asm"
000138A4                            ; ---------------------------------------------------------------------------
000138A4                            ; Subroutine to make Sonic perform a peelout
000138A4                            ; ---------------------------------------------------------------------------
000138A4                            ; If you use this makes sure to search for ;Peelout in Sonic1.asm
000138A4                            ; ||||||||||||||| S U B	R O U T	I N E |||||||||||||||||||||||||||||||||||||||
000138A4                            
000138A4                            ;SCDPeelout:
000138A4 0828 0001 0039             		btst	#1,$39(a0)
000138AA 6600                       		bne.s	SCDPeelout_Launch
000138AC 0C28 0007 001C             		cmpi.b	#7,$1C(a0) ;check to see if your looking up
000138B2 6600                       		bne.s	@return
000138B4 1038 F603                  		move.b	($FFFFF603).w,d0
000138B8 0200 0070                  		andi.b	#%01110000,d0
000138BC 6700 0000                  		beq.w	@return
000138C0 117C 0001 001C             		move.b	#1,$1C(a0)
000138C6 317C 0000 003A             		move.w	#0,$3A(a0)
000138CC 303C 00D2                  		move.w	#$D2,d0
000138D0 4EB9 0000 12C4             		jsr		(PlaySound_Special).l 	; Play peelout charge sound
000138D6                            	;	sfx 	sfx_PeeloutCharge 		; These are if you use AMPS
000138D6 588F                       		addq.l	#4,sp
000138D8 08E8 0001 0039             		bset	#1,$39(a0)
000138DE                            		
000138DE 4268 0014                  		clr.w	$14(a0)
000138E2                             
000138E2 6100 FDE4                  		bsr.w	Sonic_LevelBound
000138E6 6100 0000                  		bsr.w	Sonic_AnglePos
000138EA                             
000138EA                            	@return:
000138EA 4E75                       		rts	
000138EC                            ; ---------------------------------------------------------------------------
000138EC                             
000138EC                            SCDPeelout_Launch:
000138EC 1038 F602                  		move.b	($FFFFF602).w,d0
000138F0 0800 0000                  		btst	#0,d0
000138F4 6600 0000                  		bne.w	SCDPeelout_Charge
000138F8 08A8 0001 0039             		bclr	#1,$39(a0)	; stop Dashing
000138FE 0C28 001E 003A             		cmpi.b	#$1E,$3A(a0)	; have we been charging long enough?
00013904 6600                       		bne.s	SCDPeelout_Stop_Sound
00013906 117C 0000 001C             		move.b	#0,$1C(a0)	; launches here (peelout sprites)
0001390C 317C 0001 0010             		move.w	#1,$10(a0)	; force X speed to nonzero for camera lag's benefit
00013912 3028 0014                  		move.w	$14(a0),d0
00013916 0440 0800                  		subi.w	#$800,d0
0001391A D040                       		add.w	d0,d0
0001391C 0240 1F00                  		andi.w	#$1F00,d0
00013920 4440                       		neg.w	d0
00013922 0640 2000                  		addi.w	#$2000,d0
00013926                            		;move.w	d0,(v_cameralag).w
00013926 0828 0000 0022             		btst	#0,$22(a0)
0001392C 6700                       		beq.s	@dontflip
0001392E 4468 0014                  		neg.w	$14(a0)
00013932                             
00013932                            @dontflip:
00013932 08A8 0007 0022             		bclr	#7,$22(a0)
00013938 303C 00D4                  		move.w	#$D4,d0
0001393C 4EB9 0000 12C4             		jsr		(PlaySound_Special).l
00013942                            	;	sfx 	sfx_PeeloutRelease
00013942 6000 0000                  		bra.w	SCDPeelout_ResetScr
00013946                            ; ---------------------------------------------------------------------------
00013946                             
00013946                            SCDPeelout_Charge:				; If still charging the dash...
00013946 3238 F760                  		move.w	($FFFFF760).w,d1	; get top peelout speed
0001394A 3401                       		move.w	d1,d2
0001394C D241                       		add.w	d1,d1
0001394E 4A38 FE2E                  		tst.b   ($FFFFFE2E).w 		; test for speed shoes
00013952 6700                       		beq.s	@noshoes
00013954 E242                       		asr.w	#1,d2
00013956 9242                       		sub.w	d2,d1
00013958                            
00013958                            @noshoes:
00013958 0668 0064 0014             		addi.w	#$64,$14(a0)		; increment speed
0001395E B268 0014                  		cmp.w	$14(a0),d1
00013962 6E00                       		bgt.s	@inctimer
00013964 3141 0014                  		move.w	d1,$14(a0)
00013968                            
00013968                            @inctimer:
00013968 5228 003A                  		addq.b	#1,$3A(a0)		; increment timer
0001396C 0C28 001E 003A             		cmpi.b	#$1E,$3A(a0)
00013972 6500                       		bcs.s	SCDPeelout_ResetScr
00013974 117C 001E 003A             		move.b	#$1E,$3A(a0)
0001397A 4EF9 0000 0000             		jmp 	SCDPeelout_ResetScr
00013980                            		
00013980                            SCDPeelout_Stop_Sound:
00013980 303C 00D3                  		move.w	#$D3,d0
00013984 4EB9 0000 12C4             		jsr		(PlaySound_Special).l
0001398A                            	;	sfx 	sfx_PeeloutStop
0001398A 4268 0014                  		clr.w	$14(a0)
0001398E                            
0001398E                            SCDPeelout_ResetScr:
0001398E 588F                       		addq.l	#4,sp			; increase stack ptr ; was 4
00013990 0C78 0060 F73E             		cmpi.w	#$60,($FFFFF73E).w
00013996 6700                       		beq.s	@finish
00013998 6400                       		bcc.s	@skip
0001399A 5878 F73E                  		addq.w	#4,($FFFFF73E).w
0001399E                             
0001399E                            	@skip:
0001399E 5578 F73E                  		subq.w	#2,($FFFFF73E).w
000139A2                             
000139A2                            	@finish:
000139A2 6100 FD24                  		bsr.w	Sonic_LevelBound
000139A6 6100 0000                  		bsr.w	Sonic_AnglePos
000139AA 4E75                       		rts
000139AC                            		
000139AC                            		
000139AC 4E75                       	rts		
000139AE                            ; ---------------------------------------------------------------------------
000139AE                            ; Subroutine to perform Spin Dash
000139AE                            ; ---------------------------------------------------------------------------
000139AE                            
000139AE                            ; ||||||||||||||| S U B	R O U T	I N E |||||||||||||||||||||||||||||||||||||||
000139AE                            
000139AE                            Sonic_SpinDash:
000139AE 4A28 0039                  		tst.b	$39(a0)			; already Spin Dashing?
000139B2 6600                       		bne.s	loc2_1AC8E		; if set, branch
000139B4 0C28 0008 001C             		cmpi.b	#8,$1C(a0)		; is anim duck
000139BA 6600                       		bne.s	locret2_1AC8C		; if not, return
000139BC 1038 F603                  		move.b	($FFFFF603).w,d0	; read controller
000139C0 0200 0070                  		andi.b	#$70,d0			; pressing A/B/C ?
000139C4 6700 0000                  		beq.w	locret2_1AC8C		; if not, return
000139C8 117C 001F 001C             		move.b	#$1F,$1C(a0)		; set Spin Dash anim (9 in s2)
000139CE 303C 00D1                  		move.w	#$D1,d0			; spin sound ($E0 in s2)
000139D2 4EB9 0000 12C4             		jsr	(PlaySound_Special).l	; play spin sound
000139D8 588F                       		addq.l	#4,sp			; increment stack ptr
000139DA 117C 0001 0039             		move.b	#1,$39(a0)		; set Spin Dash flag
000139E0 317C 0000 003A             		move.w	#0,$3A(a0)		; set charge count to 0
000139E6 0C28 000C 0028             		cmpi.b	#$C,$28(a0)		; ??? oxygen remaining?
000139EC 11FC 0002 D1DC             		move.b	#2,($FFFFD1DC).w	; Set the Spin Dash dust animation to $2
000139F2                            
000139F2                            loc2_1AC84:
000139F2 4EBA FCD4                  		jsr	Sonic_LevelBound
000139F6 4EB9 0000 0000             		jsr	Sonic_AnglePos
000139FC                            
000139FC                            locret2_1AC8C:
000139FC 4E75                       		rts	
000139FE                            ; ---------------------------------------------------------------------------
000139FE                            
000139FE                            loc2_1AC8E:
000139FE 117C 001F 001C             		move.b	#$1F,$1C(a0)
00013A04 1038 F602                  		move.b	($FFFFF602).w,d0	; read controller
00013A08 0800 0001                  		btst	#1,d0			; check down button
00013A0C 6600 0000                  		bne.w	loc2_1AD30		; if set, branch
00013A10 117C 000E 0016             		move.b	#$E,$16(a0)		; $16(a0) is height/2
00013A16 117C 0007 0017             		move.b	#7,$17(a0)		; $17(a0) is width/2
00013A1C 117C 0002 001C             		move.b	#2,$1C(a0)		; set animation to roll
00013A22 5A68 000C                  		addq.w	#5,$C(a0)		; $C(a0) is Y coordinate
00013A26 117C 0000 0039             		move.b	#0,$39(a0)		; clear Spin Dash flag
00013A2C 7000                       		moveq	#0,d0
00013A2E 1028 003A                  		move.b	$3A(a0),d0		; copy charge count
00013A32 D040                       		add.w	d0,d0			; double it
00013A34 317B 0000 0014             		move.w	spdsh_norm(pc,d0.w),$14(a0) ; get normal speed
00013A3A 4A38 FE19                  		tst.b	($FFFFFE19).w		; is sonic super?
00013A3E 6700                       		beq.s	loc2_1ACD0		; if no, branch
00013A40 317B 0000 0014             		move.w	spdsh_super(pc,d0.w),$14(a0) ; get super speed
00013A46                            
00013A46                            loc2_1ACD0:					; TODO: figure this out
00013A46 3028 0014                  		move.w	$14(a0),d0		; get inertia
00013A4A 0440 0800                  		subi.w	#$800,d0		; subtract $800
00013A4E D040                       		add.w	d0,d0			; double it
00013A50 0240 1F00                  		andi.w	#$1F00,d0		; mask it against $1F00
00013A54 4440                       		neg.w	d0			; negate it
00013A56 0640 2000                  		addi.w	#$2000,d0		; add $2000
00013A5A 31C0 C904                  		move.w	d0,($FFFFC904).w	; move to $EED0
00013A5E 0828 0000 0022             		btst	#0,$22(a0)		; is sonic facing right?
00013A64 6700                       		beq.s	loc2_1ACF4		; if not, branch
00013A66 4468 0014                  		neg.w	$14(a0)			; negate inertia
00013A6A                            
00013A6A                            loc2_1ACF4:
00013A6A 08E8 0002 0022             		bset	#2,$22(a0)		; set unused (in s1) flag
00013A70 11FC 0000 D1DC             		move.b	#0,($FFFFD1DC).w	; clear Spin Dash dust animation
00013A76 303C 00BC                  		move.w	#$BC,d0			; spin release sound
00013A7A 4EB9 0000 12C4             		jsr	(PlaySound_Special).l	; play it!
00013A80 11FC 0008 FF5B             		move.b	#8,($FFFFFF5B).w 	; set afterimage counter to 8
00013A86 6000                       		bra.s	loc2_1AD78
00013A88                            ; ───────────────────────────────────────────────────────────────────────────
00013A88                            spdsh_norm:
00013A88 0800                       		dc.w  $800		; 0
00013A8A 0880                       		dc.w  $880		; 1
00013A8C 0900                       		dc.w  $900		; 2
00013A8E 0980                       		dc.w  $980		; 3
00013A90 0A00                       		dc.w  $A00		; 4
00013A92 0A80                       		dc.w  $A80		; 5
00013A94 0B00                       		dc.w  $B00		; 6
00013A96 0B80                       		dc.w  $B80		; 7
00013A98 0C00                       		dc.w  $C00		; 8
00013A9A                            
00013A9A                            spdsh_super:
00013A9A 0B00                       		dc.w  $B00		; 0
00013A9C 0B80                       		dc.w  $B80		; 1
00013A9E 0C00                       		dc.w  $C00		; 2
00013AA0 0C80                       		dc.w  $C80		; 3
00013AA2 0D00                       		dc.w  $D00		; 4
00013AA4 0D80                       		dc.w  $D80		; 5
00013AA6 0E00                       		dc.w  $E00		; 6
00013AA8 0E80                       		dc.w  $E80		; 7
00013AAA 0F00                       		dc.w  $F00		; 8
00013AAC                            ; ───────────────────────────────────────────────────────────────────────────
00013AAC                            
00013AAC                            loc2_1AD30:				; If still charging the dash...
00013AAC 4A68 003A                  		tst.w	$3A(a0)		; check charge count
00013AB0 6700                       		beq.s	loc2_1AD48	; if zero, branch
00013AB2 3028 003A                  		move.w	$3A(a0),d0	; otherwise put it in d0
00013AB6 EA48                       		lsr.w	#5,d0		; shift right 5 (divide it by 32)
00013AB8 9168 003A                  		sub.w	d0,$3A(a0)	; subtract from charge count
00013ABC 6400                       		bcc.s	loc2_1AD48	; ??? branch if carry clear
00013ABE 317C 0000 003A             		move.w	#0,$3A(a0)	; set charge count to 0
00013AC4                            
00013AC4                            loc2_1AD48:
00013AC4 1038 F603                  		move.b	($FFFFF603).w,d0	; read controller
00013AC8 0200 0070                  		andi.b	#$70,d0			; pressing A/B/C?
00013ACC 6700 0000                  		beq.w	loc2_1AD78		; if not, branch
00013AD0 317C 1F00 001C             		move.w	#$1F00,$1C(a0)		; reset spdsh animation
00013AD6 303C 00D1                  		move.w	#$D1,d0			; was $E0 in sonic 2
00013ADA 11FC 0002 D1DC             		move.b	#2,$FFFFD1DC.w	; Set the Spin Dash dust animation to $2.
00013AE0 4EB9 0000 12C4             		jsr	(PlaySound_Special).l	; play charge sound
00013AE6 0668 0200 003A             		addi.w	#$200,$3A(a0)		; increase charge count
00013AEC 0C68 0800 003A             		cmpi.w	#$800,$3A(a0)		; check if it's maxed
00013AF2 6500                       		bcs.s	loc2_1AD78		; if not, then branch
00013AF4 317C 0800 003A             		move.w	#$800,$3A(a0)		; reset it to max
00013AFA                            
00013AFA                            loc2_1AD78:
00013AFA 588F                       		addq.l	#4,sp			; increase stack ptr
00013AFC 0C78 0060 F73E             		cmpi.w	#$60,($FFFFF73E).w
00013B02 6700                       		beq.s	loc2_1AD8C
00013B04 6400                       		bcc.s	loc2_1AD88
00013B06 5878 F73E                  		addq.w	#4,($FFFFF73E).w
00013B0A                            
00013B0A                            loc2_1AD88:
00013B0A 5578 F73E                  		subq.w	#2,($FFFFF73E).w
