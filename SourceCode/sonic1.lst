0001CD08 1238 FE23                  		move.b	($FFFFFE23).w,d1 ; load	minutes
0001CD0C 6100 0000                  		bsr.w	Hud_Mins
0001CD16 7200                       		moveq	#0,d1
0001CD18 1238 FE24                  		move.b	($FFFFFE24).w,d1 ; load	seconds
0001CD1C 6100 0000                  		bsr.w	Hud_Secs
0001CD20                            
