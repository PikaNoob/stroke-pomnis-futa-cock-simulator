0000D5F8                            ; Subroutine to	make an	object fall downwards, increasingly fast
0000D5F8                            ; ---------------------------------------------------------------------------
0000D5F8                            
0000D5F8                            ; ||||||||||||||| S U B	R O U T	I N E |||||||||||||||||||||||||||||||||||||||
0000D5F8                            
0000D5F8                            
0000D5F8                            ObjectFall:
0000D5F8 3028 0010                  		move.w	$10(a0),d0
0000D5FC 48C0                       		ext.l	d0
0000D5FE E188                       		lsl.l	#8,d0
0000D600 D1A8 0008                  		add.l	d0,8(a0)
0000D604 3028 0012                  		move.w	$12(a0),d0
0000D608 0668 0038 0012             		addi.w	#$38,$12(a0)	; increase vertical speed
0000D60E 48C0                       		ext.l	d0
0000D610 E188                       		lsl.l	#8,d0
0000D612 D1A8 000C                  		add.l	d0,$C(a0)
0000D616 4E75                       		rts	
0000D618                            
0000D618                            ; End of function ObjectFall
