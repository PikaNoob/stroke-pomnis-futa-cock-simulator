0001CDCE 7200                       		moveq	#0,d1
0001CDD0 3238 F7D4                  		move.w	($FFFFF7D4).w,d1 ; load	ring bonus
0001CDD4 6100 0000                  		bsr.w	Hud_TimeRingBonus
