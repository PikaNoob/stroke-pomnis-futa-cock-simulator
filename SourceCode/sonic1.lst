0001CF4E 0242 000F                  		andi.w	#$F,d2		; get low 4 bits representing digit
0001CF52 0C42 000A                  		cmpi.w	#$A,d2		; is digit more or equals to $A?
0001CF56 6500                       		bcs.s	@WriteTile	; if not, branch
