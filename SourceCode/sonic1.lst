000012E8 3A80                       		move.w	d0,(a5)		; transfer length
000012EA 3A99                       		move.w	(a1)+,(a5)	; transfer length
000012EC 3A99                       		move.w	(a1)+,(a5)	; source address
000012EE 3A99                       		move.w	(a1)+,(a5)	; source address
000012F0 3A99                       		move.w	(a1)+,(a5)	; source address
000012F2 3A99                       		move.w	(a1)+,(a5)	; destination
000012F4 3A99                       		move.w	(a1)+,(a5)	; destination
000012F6 B2FC C8FC                  		cmpa.w	#$C8FC,a1
000012FA 66E8                       		bne.s	ProcessDMAQueue_Loop ; loop if we haven't reached the end of the buffer
