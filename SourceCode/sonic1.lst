00013A44 7000                       		moveq	#0,d0
00013A46 1028 003A                  		move.b	$3A(a0),d0		; copy charge count
00013A4A D040                       		add.w	d0,d0			; double it
00013A4C 317B 0000 0014             		move.w	spdsh_norm(pc,d0.w),$14(a0) ; get normal speed
00013A52 4A38 FE19                  		tst.b	($FFFFFE19).w		; is sonic super?
00013A56 6700                       		beq.s	loc2_1ACD0		; if no, branch
