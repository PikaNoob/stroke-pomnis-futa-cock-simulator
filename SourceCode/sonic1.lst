0000C8D8 7200                       		moveq	#0,d1
0000C8DA 1238 FE57                  		move.b	($FFFFFE57).w,d1 ; d1 is number	of emeralds
0000C8DE 5301                       		subq.b	#1,d1		; subtract 1 from d1
