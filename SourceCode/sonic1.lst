000020DE                            PalLoad1:
000020DE 43F9 0000 0000             		lea	(PalPointers).l,a1
000020E4 E748                       		lsl.w	#3,d0		; multiple pallete index by 8
000020E6 D2C0                       		adda.w	d0,a1
000020E8 2459                       		movea.l	(a1)+,a2	; load pallete offset in ROM
000020EA 3659                       		movea.w	(a1)+,a3	; load RAM destination
000020EC D6FC 0080                  		adda.w	#$80,a3
000020F0 3E19                       		move.w	(a1)+,d7	; load pallete lenght
000020F2                            
000020F2 26DA                       @WritePallete:	move.l	(a2)+,(a3)+	; move pallete from ROM to RAM
000020F4 51CF FFFC                  		dbf	d7,@WritePallete ; repeat for the lenght of the pallete
000020F8 4E75                       		rts	
