0001CDCA 7200                       		moveq	#0,d1
0001CDCC 1238 FE23                  		move.b	($FFFFFE23).w,d1 ; load	minutes
0001CDD0 6100 0000                  		bsr.w	Hud_Mins
0001CDDA 7200                       		moveq	#0,d1
0001CDDC 1238 FE24                  		move.b	($FFFFFE24).w,d1 ; load	seconds
0001CDE0 6100 0000                  		bsr.w	Hud_Secs
