00001EC6                            Pal_AddColor2: ; XREF: Pal_ToWhite
00001EC6 3A10                               move.w (a0),d5 ; MJ: load colour
00001EC8 0C45 0EEE                          cmpi.w #$EEE,d5
00001ECC 6700                               beq.s FCO2_NoRed
00001ECE 3205                               move.w d5,d1 ; MJ: copy to d1
00001ED0 1401                               move.b d1,d2 ; MJ: load green and red
00001ED2 1601                               move.b d1,d3 ; MJ: load red
00001ED4 0241 0E00                          andi.w #$0E00,d1 ; MJ: get only blue
00001ED8 0C41 0E00                          cmpi.w #$0E00,d1
00001EDC 6700 0000                          beq FCO2_NoBlue ; MJ: if blue is finished, branch
00001EE0 0645 0200                          addi.w #$0200,d5 ; MJ: increase blue
00001EE4                            
00001EE4                            FCO2_NoBlue:
00001EE4 0242 00E0                          andi.w #$00E0,d2 ; MJ: get only green (needs to be word)
00001EE8 0C42 00E0                          cmpi.w #$00E0,d2
00001EEC 6700 0000                          beq FCO2_NoGreen ; MJ: if green is finished, branch
00001EF0 0605 0020                          addi.b #$20,d5 ; MJ: increase green
00001EF4                            
00001EF4                            FCO2_NoGreen:
00001EF4 0203 000E                          andi.b #$0E,d3 ; MJ: get only red
00001EF8 0C03 000E                          cmpi.b #$0E,d3
00001EFC 6700 0000                          beq FCO2_NoRed ; MJ: if red is finished, branch
00001F00 5405                               addq.b #$02,d5 ; MJ: increase red
00001F02                            
00001F02                            FCO2_NoRed:
00001F02 30C5                               move.w d5,(a0)+ ; MJ: save new colour
00001F04 4E75                               rts ; MJ: return
00001F06                            ; End of function Pal_AddColor2
