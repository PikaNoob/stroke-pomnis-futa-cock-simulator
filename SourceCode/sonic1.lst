000031F2 103C 009D                  		move.b	#$9D,d0
000031F6 6100 DFE6                  		bsr.w	PlaySound_Special ; play credits music
000031FA 31FC 0000 FFF4             		move.w	#0,($FFFFFFF4).w
00003200 4E75                       		rts	
