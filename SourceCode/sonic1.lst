00001F2A                            
00001F2A                            
00001F2A                            ; ||||||||||||||| S U B R O U T I N E |||||||||||||||||||||||||||||||||||||||
00001F2A                            
00001F2A                            
00001F2A                            Pal_DecColor2: ; XREF: Pal_WhiteToBlack
00001F2A 1A11                               move.b (a1),d5 ; MJ: load blue
00001F2C 3219                               move.w (a1)+,d1 ; MJ: load green and red
00001F2E 1401                               move.b d1,d2 ; MJ: load red
00001F30 E809                               lsr.b #$04,d1 ; MJ: get only green
00001F32 0202 000E                          andi.b #$0E,d2 ; MJ: get only red
00001F36 3610                               move.w (a0),d3 ; MJ: load current colour in buffer
00001F38 B805                               cmp.b d5,d4 ; MJ: is it time for blue to fade?
00001F3A 6300 0000                          bls FCI2_NoBlue ; MJ: if not, branch
00001F3E 0443 0200                          subi.w #$0200,d3 ; MJ: dencrease blue
00001F42                            
00001F42                            FCI2_NoBlue:
00001F42 B801                               cmp.b d1,d4 ; MJ: is it time for green to fade?
00001F44 6300 0000                          bls FCI2_NoGreen ; MJ: if not, branch
00001F48 0403 0020                          subi.b #$20,d3 ; MJ: dencrease green
00001F4C                            
00001F4C                            FCI2_NoGreen:
00001F4C B802                               cmp.b d2,d4 ; MJ: is it time for red to fade?
00001F4E 6300 0000                          bls FCI2_NoRed ; MJ: if not, branch
00001F52 5503                               subq.b #$02,d3 ; MJ: dencrease red
00001F54                            
00001F54                            FCI2_NoRed:
00001F54 30C3                               move.w d3,(a0)+ ; MJ: save colour
00001F56 4E75                               rts ; MJ: return
00001F58                            ; End of function Pal_DecColor2
