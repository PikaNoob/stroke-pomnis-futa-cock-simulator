0001CD2E                            ; Add points subroutine
0001CD2E                            ; ---------------------------------------------------------------------------
0001CD2E                            
0001CD2E                            ; ||||||||||||||| S U B	R O U T	I N E |||||||||||||||||||||||||||||||||||||||
0001CD2E                            
0001CD2E                            
0001CD2E                            AddPoints:
0001CD2E 11FC 0001 FE1F             		move.b	#1,($FFFFFE1F).w ; set score counter to	update
0001CD34 45F8 FFC0                  		lea	($FFFFFFC0).w,a2
0001CD38 47F8 FE26                  		lea	($FFFFFE26).w,a3
0001CD3C D193                       		add.l	d0,(a3)		; add d0*10 to the score
0001CD3E 223C 000F 423F             		move.l	#999999,d1
0001CD44 B293                       		cmp.l	(a3),d1		; is #999999 higher than the score?
0001CD46 6200 0000                  		bhi.w	loc_1C6AC	; if yes, branch
0001CD4A 2681                       		move.l	d1,(a3)		; reset	score to #999999
0001CD4C 2481                       		move.l	d1,(a2)
0001CD4E                            
0001CD4E                            loc_1C6AC:
0001CD4E 2013                       		move.l	(a3),d0
0001CD50 B092                       		cmp.l	(a2),d0
0001CD52 6500 0000                  		bcs.w	locret_1C6B6
0001CD56 2480                       		move.l	d0,(a2)
