00013F42                            ; ---------------------------------------------------------------------------
00013F42                            ; Subroutine to	animate	Sonic's sprites
00013F42                            ; ---------------------------------------------------------------------------
00013F42                            
00013F42                            ; ||||||||||||||| S U B	R O U T	I N E |||||||||||||||||||||||||||||||||||||||
00013F42                            
00013F42                            
00013F42                            Sonic_Animate:				; XREF: Obj01_Control; et al
00013F42 43F9 0000 0000             		lea	(SonicAniData).l,a1
00013F48 7000                       		moveq	#0,d0
00013F4A 1028 001C                  		move.b	$1C(a0),d0
00013F4E B028 001D                  		cmp.b	$1D(a0),d0	; is animation set to restart?
00013F52 6700                       		beq.s	SAnim_Do	; if not, branch
00013F54 1140 001D                  		move.b	d0,$1D(a0)	; set to "no restart"
00013F58 117C 0000 001B             		move.b	#0,$1B(a0)	; reset	animation
00013F5E 117C 0000 001E             		move.b	#0,$1E(a0)	; reset	frame duration
00013F64                            
00013F64                            SAnim_Do:
00013F64 D040                       		add.w	d0,d0
00013F66 D2F1 0000                  		adda.w	(a1,d0.w),a1	; jump to appropriate animation	script
00013F6A 1011                       		move.b	(a1),d0
00013F6C 6B00                       		bmi.s	SAnim_WalkRun	; if animation is walk/run/roll/jump, branch
00013F6E 1228 0022                  		move.b	$22(a0),d1
00013F72 0201 0001                  		andi.b	#1,d1
00013F76 0228 00FC 0001             		andi.b	#$FC,1(a0)
00013F7C 8328 0001                  		or.b	d1,1(a0)
00013F80 5328 001E                  		subq.b	#1,$1E(a0)	; subtract 1 from frame	duration
00013F84 6A00                       		bpl.s	SAnim_Delay	; if time remains, branch
00013F86 1140 001E                  		move.b	d0,$1E(a0)	; load frame duration
00013F8A                            
00013F8A                            SAnim_Do2:
00013F8A 7200                       		moveq	#0,d1
00013F8C 1228 001B                  		move.b	$1B(a0),d1	; load current frame number
00013F90 1031 1001                  		move.b	1(a1,d1.w),d0	; read sprite number from script
00013F94 6B00                       		bmi.s	SAnim_End_FF	; if animation is complete, branch
00013F96                            
00013F96                            SAnim_Next:
00013F96 1140 001A                  		move.b	d0,$1A(a0)	; load sprite number
00013F9A 5228 001B                  		addq.b	#1,$1B(a0)	; next frame number
00013F9E                            
00013F9E                            SAnim_Delay:
00013F9E 4E75                       		rts	
00013FA0                            ; ===========================================================================
00013FA0                            
00013FA0                            SAnim_End_FF:
00013FA0 5200                       		addq.b	#1,d0		; is the end flag = $FF	?
00013FA2 6600                       		bne.s	SAnim_End_FE	; if not, branch
00013FA4 117C 0000 001B             		move.b	#0,$1B(a0)	; restart the animation
00013FAA 1029 0001                  		move.b	1(a1),d0	; read sprite number
00013FAE 60E6                       		bra.s	SAnim_Next
00013FB0                            ; ===========================================================================
00013FB0                            
00013FB0                            SAnim_End_FE:
00013FB0 5200                       		addq.b	#1,d0		; is the end flag = $FE	?
00013FB2 6600                       		bne.s	SAnim_End_FD	; if not, branch
00013FB4 1031 1002                  		move.b	2(a1,d1.w),d0	; read the next	byte in	the script
00013FB8 9128 001B                  		sub.b	d0,$1B(a0)	; jump back d0 bytes in	the script
00013FBC 9200                       		sub.b	d0,d1
00013FBE 1031 1001                  		move.b	1(a1,d1.w),d0	; read sprite number
00013FC2 60D2                       		bra.s	SAnim_Next
00013FC4                            ; ===========================================================================
00013FC4                            
00013FC4                            SAnim_End_FD:
00013FC4 5200                       		addq.b	#1,d0		; is the end flag = $FD	?
00013FC6 6600                       		bne.s	SAnim_End	; if not, branch
00013FC8 1171 1002 001C             		move.b	2(a1,d1.w),$1C(a0) ; read next byte, run that animation
00013FCE                            
00013FCE                            SAnim_End:
00013FCE 4E75                       		rts	
00013FD0                            ; ===========================================================================
00013FD0                            
00013FD0                            SAnim_WalkRun:				; XREF: SAnim_Do
00013FD0 5328 001E                  		subq.b	#1,$1E(a0)	; subtract 1 from frame	duration
00013FD4 6AC8                       		bpl.s	SAnim_Delay	; if time remains, branch
00013FD6 5200                       		addq.b	#1,d0		; is animation walking/running?
00013FD8 6600 0000                  		bne.w	SAnim_RollJump	; if not, branch
00013FDC 7200                       		moveq	#0,d1
00013FDE 1028 0026                  		move.b	$26(a0),d0	; get Sonic's angle
00013FE2 1428 0022                  		move.b	$22(a0),d2
00013FE6 0202 0001                  		andi.b	#1,d2		; is Sonic mirrored horizontally?
00013FEA 6600                       		bne.s	loc_13A70	; if yes, branch
00013FEC 4600                       		not.b	d0		; reverse angle
00013FEE                            
00013FEE                            loc_13A70:
00013FEE 0600 0010                  		addi.b	#$10,d0		; add $10 to angle
00013FF2 6A00                       		bpl.s	loc_13A78	; if angle is $0-$7F, branch
00013FF4 7203                       		moveq	#3,d1
00013FF6                            
00013FF6                            loc_13A78:
00013FF6 0228 00FC 0001             		andi.b	#$FC,1(a0)
00013FFC B302                       		eor.b	d1,d2
00013FFE 8528 0001                  		or.b	d2,1(a0)
00014002 0828 0005 0022             		btst	#5,$22(a0)
00014008 6600 0000                  		bne.w	SAnim_Push
0001400C E808                       		lsr.b	#4,d0		; divide angle by $10
0001400E 0200 0006                  		andi.b	#6,d0		; angle	must be	0, 2, 4	or 6
00014012 3428 0014                  		move.w	$14(a0),d2	; get Sonic's speed
00014016 6A00                       		bpl.s	loc_13A9C
00014018 4442                       		neg.w	d2
0001401A                            
0001401A                            loc_13A9C:
0001401A 43F9 0000 0000             		lea	(SonAni_Run).l,a1 ; use	running	animation
00014020 0C42 0600                  		cmpi.w	#$600,d2	; is Sonic at running speed?
00014024 6400                       		bcc.s	loc_13AB4	; if yes, branch
00014026 43F9 0000 0000             		lea	(SonAni_Walk).l,a1 ; use walking animation
0001402C 1200                       		move.b	d0,d1
0001402E E209                       		lsr.b	#1,d1
00014030 D001                       		add.b	d1,d0
00014032                            
00014032                            loc_13AB4:
00014032 D000                       		add.b	d0,d0
00014034 1600                       		move.b	d0,d3
00014036 4442                       		neg.w	d2
00014038 0642 0800                  		addi.w	#$800,d2
0001403C 6A00                       		bpl.s	loc_13AC2
0001403E 7400                       		moveq	#0,d2
00014040                            
00014040                            loc_13AC2:
00014040 E04A                       		lsr.w	#8,d2
00014042 1142 001E                  		move.b	d2,$1E(a0)	; modify frame duration
00014046 6100 FF42                  		bsr.w	SAnim_Do2
0001404A D728 001A                  		add.b	d3,$1A(a0)	; modify frame number
0001404E 4E75                       		rts	
00014050                            ; ===========================================================================
00014050                            
00014050                            SAnim_RollJump:				; XREF: SAnim_WalkRun
00014050 5200                       		addq.b	#1,d0		; is animation rolling/jumping?
00014052 6600                       		bne.s	SAnim_Push	; if not, branch
00014054 3428 0014                  		move.w	$14(a0),d2	; get Sonic's speed
00014058 6A00                       		bpl.s	loc_13ADE
0001405A 4442                       		neg.w	d2
0001405C                            
0001405C                            loc_13ADE:
0001405C 43F9 0000 0000             		lea	(SonAni_Roll2).l,a1 ; use fast animation
00014062 0C42 0600                  		cmpi.w	#$600,d2	; is Sonic moving fast?
00014066 6400                       		bcc.s	loc_13AF0	; if yes, branch
00014068 43F9 0000 0000             		lea	(SonAni_Roll).l,a1 ; use slower	animation
0001406E                            
0001406E                            loc_13AF0:
0001406E 4442                       		neg.w	d2
00014070 0642 0400                  		addi.w	#$400,d2
00014074 6A00                       		bpl.s	loc_13AFA
00014076 7400                       		moveq	#0,d2
00014078                            
00014078                            loc_13AFA:
00014078 E04A                       		lsr.w	#8,d2
0001407A 1142 001E                  		move.b	d2,$1E(a0)	; modify frame duration
0001407E 1228 0022                  		move.b	$22(a0),d1
00014082 0201 0001                  		andi.b	#1,d1
00014086 0228 00FC 0001             		andi.b	#$FC,1(a0)
0001408C 8328 0001                  		or.b	d1,1(a0)
00014090 6000 FEF8                  		bra.w	SAnim_Do2
00014094                            ; ===========================================================================
00014094                            
00014094                            SAnim_Push:				; XREF: SAnim_RollJump
00014094 3428 0014                  		move.w	$14(a0),d2	; get Sonic's speed
00014098 6B00                       		bmi.s	loc_13B1E
0001409A 4442                       		neg.w	d2
0001409C                            
0001409C                            loc_13B1E:
