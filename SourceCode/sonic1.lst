00001366 B2FC C8FC                  		cmpa.w	#$C8FC,a1
0000136A 6700                       		beq.s	QueueDMATransfer_Done ; return if there's no more room in the buffer
0000136C                             
0000136C 303C 9300                  		move.w	#$9300,d0 ; command to specify DMA transfer length & $00FF
00001370 1003                       		move.b	d3,d0
00001372 32C0                       		move.w	d0,(a1)+ ; store command
00001374                             
00001374 303C 9400                  		move.w	#$9400,d0 ; command to specify DMA transfer length & $FF00
00001378 E04B                       		lsr.w	#8,d3
0000137A 1003                       		move.b	d3,d0
0000137C 32C0                       		move.w	d0,(a1)+ ; store command
0000137E                             
0000137E 303C 9500                  		move.w	#$9500,d0 ; command to specify source address & $0001FE
00001382 E289                       		lsr.l	#1,d1
00001384 1001                       		move.b	d1,d0
00001386 32C0                       		move.w	d0,(a1)+ ; store command
00001388                             
00001388 303C 9600                  		move.w	#$9600,d0 ; command to specify source address & $01FE00
0000138C E089                       		lsr.l	#8,d1
0000138E 1001                       		move.b	d1,d0
00001390 32C0                       		move.w	d0,(a1)+ ; store command
00001392                             
00001392 303C 9700                  		move.w	#$9700,d0 ; command to specify source address & $FE0000
00001396 E089                       		lsr.l	#8,d1
00001398 1001                       		move.b	d1,d0
0000139A 32C0                       		move.w	d0,(a1)+ ; store command
0000139C                             
0000139C 0282 0000 FFFF             		andi.l	#$FFFF,d2 ; command to specify destination address and begin DMA
000013A2 E58A                       		lsl.l	#2,d2
000013A4 E44A                       		lsr.w	#2,d2
