0000D650                            
0000D650                            DisplaySprite2:
0000D650 45F8 AC00                  		lea	($FFFFAC00).w,a2 ; load sprite table
0000D654 3029 0018                  		move.w	$18(a1),d0	; load object's prioity and horizontal radius
0000D658 E248                       		lsr.w	#1,d0		; shift 1 bit right
0000D65A 0240 0380                  		andi.w	#$380,d0	; apply bit mask to erase obj radius value
0000D65E D4C0                       		adda.w	d0,a2		; set sprite table destination, depending on priority
0000D660 0C52 007E                  		cmpi.w	#$7E,(a2)	; is sprite table overflowed?
0000D664 6400                       		bcc.s	DisplaySprite2_Rts ; if yes, branch
0000D666 5452                       		addq.w	#2,(a2)
0000D668 D4D2                       		adda.w	(a2),a2		; load free slot in sprite table
0000D66A 3489                       		move.w	a1,(a2)		; write obj address to that slot
0000D66C                            
0000D66C                            DisplaySprite2_Rts:
0000D66C 4E75                       		rts
0000D66E                            ; End of function DisplaySprite2
